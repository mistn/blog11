---
import PageHeader from "@/components/PageHeader.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import SiteTopbar from "@/components/SiteTopbar.astro";
import Layout from "@/layouts/Layout.astro";
import animeData from "@/data/anime.generated.json";
import type { AnimeDataPayload, AnimeItem } from "@/types/anime";
import { getDateLocale, ui } from "@/i18n";

const locale = "en";
const copy = ui[locale];
const data = animeData as AnimeDataPayload;

function getEntryKey(entry: AnimeItem) {
  return (
    entry.url || [entry.title.trim(), entry.cover, entry.year ?? ""].join("::")
  );
}

function normalizeItems(items: AnimeItem[]) {
  const seen = new Set<string>();
  const list: AnimeItem[] = [];

  for (const item of items ?? []) {
    const key = getEntryKey(item);
    if (!item?.title || !item?.cover || !item?.url || seen.has(key)) continue;
    seen.add(key);
    list.push(item);
  }

  return list;
}

function groupItems(items: AnimeItem[]) {
  const groups = new Map<string, AnimeItem[]>();

  for (const item of items ?? []) {
    const yearLabel = item.year ? String(item.year) : copy.anime.unknownYear;
    const list = groups.get(yearLabel);

    if (list) list.push(item);
    else groups.set(yearLabel, [item]);
  }

  return Array.from(groups.entries())
    .sort((a, b) => Number(b[0] || 0) - Number(a[0] || 0))
    .map(([yearLabel, entries]) => ({
      yearLabel,
      entries,
    }));
}

const entries = normalizeItems(data.items ?? []);
const groups = groupItems(entries);
const total = entries.length;
const pageTitle = copy.pages.animeFullTitle;
const pageDescription = copy.pages.animeDesc;
const sourceHref = data.username
  ? `https://anilist.co/user/${data.username}`
  : "https://anilist.co";

const updatedLabel = data.updatedAt
  ? new Intl.DateTimeFormat(getDateLocale(locale), {
      year: "numeric",
      month: "2-digit",
      day: "2-digit",
      hour: "2-digit",
      minute: "2-digit",
      hour12: false,
      timeZone: "Asia/Shanghai",
    }).format(new Date(data.updatedAt))
  : null;
---

<Layout
  title={pageTitle}
  description={pageDescription}
  structuredDataType="CollectionPage"
  structuredData={{
    mainEntity: {
      "@type": "ItemList",
      name: copy.anime.itemListName,
      numberOfItems: total,
    },
    about: "AniList completed anime collection filtered by custom list normal.",
  }}
  {locale}
>
  <SiteTopbar />

  <main class="mx-auto max-w-5xl px-4 pb-14" data-pagefind-body>
    <PageHeader title={copy.pages.animeTitle}>
      <dl class="flex flex-wrap gap-x-6 gap-y-0.5">
        <div class="flex items-center gap-1.5">
          <dt class="text-foreground/45">Total</dt>
          <dd>{total} {copy.anime.countUnit}</dd>
        </div>
        <div class="flex items-center gap-1.5">
          <dt class="text-foreground/45">{copy.anime.dataFrom}</dt>
          <dd>
            <a
              href={sourceHref}
              target="_blank"
              rel="noreferrer"
              class="text-accent underline decoration-accent/35 underline-offset-4"
            >
              AniList{data.username ? ` / ${data.username}` : ""}
            </a>
          </dd>
        </div>
        <div class="flex items-center gap-1.5">
          <dt class="text-foreground/45">List</dt>
          <dd>normal / completed</dd>
        </div>
        {
          updatedLabel && (
            <div class="flex items-center gap-1.5">
              <dt class="text-foreground/45">{copy.anime.updatedAt}</dt>
              <dd>{updatedLabel}</dd>
            </div>
          )
        }
      </dl>
    </PageHeader>

    <div class="mb-12 inline-flex rounded-full bg-muted/60 p-1" role="tablist" aria-label={copy.anime.viewMode}>
      <button type="button" data-anime-toggle="all" aria-pressed="true"
        class="rounded-full px-5 py-1.5 text-sm font-medium transition-all
        aria-pressed:bg-background aria-pressed:text-foreground aria-pressed:shadow-sm
        text-foreground/50 hover:text-foreground/70">
        {copy.anime.viewAll}
      </button>
      <button type="button" data-anime-toggle="year" aria-pressed="false"
        class="rounded-full px-5 py-1.5 text-sm font-medium transition-all
        aria-pressed:bg-background aria-pressed:text-foreground aria-pressed:shadow-sm
        text-foreground/50 hover:text-foreground/70">
        {copy.anime.viewByYear}
      </button>
    </div>

    {
          entries.length > 0 ? (
            <div class="anime-view" data-anime-view="all">
              <div class="anime-archive anime-archive--all" data-anime-pane="all">
                <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 sm:gap-4">
                  {entries.map(entry => (
                    <a
                      href={entry.url}
                      target="_blank"
                      rel="noreferrer"
                      class="group relative overflow-hidden rounded-xl shadow-sm ring-1 ring-border/40 transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:ring-border/60 aspect-[2/3]"
                    >
                      <img
                        src={entry.cover}
                        alt={`${entry.title} cover`}
                        loading="lazy"
                        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                      />
                      <div class="absolute bottom-0 left-0 w-full bg-gradient-to-t from-black/80 via-black/40 to-transparent px-2.5 pt-6 pb-2.5">
                        <h3 class="line-clamp-2 text-[0.82rem] font-semibold leading-snug text-white sm:text-[0.88rem]">{entry.title}</h3>
                        <p class="mt-1 text-[0.72rem] text-white/60 sm:text-[0.75rem]">
                          {entry.year ? entry.year : copy.anime.unknownYear}
                        </p>
                      </div>
                    </a>
                  ))}
                </div>
              </div>

              <div class="anime-archive anime-archive--year" data-anime-pane="year">
                {groups.map(group => (
                  <section class="anime-year-section">
                    <div class="anime-year-heading">
                      <h2>{group.yearLabel}</h2>
                      <p>
                        {group.entries.length} {copy.anime.countUnit}
                      </p>
                    </div>

                    <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 sm:gap-4">
                      {group.entries.map(entry => (
                        <a
                          href={entry.url}
                          target="_blank"
                          rel="noreferrer"
                          class="group relative overflow-hidden rounded-xl shadow-sm ring-1 ring-border/40 transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:ring-border/60 aspect-[2/3]"
                        >
                          <img
                            src={entry.cover}
                            alt={`${entry.title} cover`}
                            loading="lazy"
                            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                          />
                          <div class="absolute bottom-0 left-0 w-full bg-gradient-to-t from-black/80 via-black/40 to-transparent px-2.5 pt-6 pb-2.5">
                            <h3 class="line-clamp-2 text-[0.82rem] font-semibold leading-snug text-white sm:text-[0.88rem]">{entry.title}</h3>
                            <p class="mt-1 text-[0.72rem] text-white/60 sm:text-[0.75rem]">
                              {entry.year ? entry.year : copy.anime.unknownYear}
                            </p>
                          </div>
                        </a>
                      ))}
                    </div>
                  </section>
                ))}
              </div>
            </div>
          ) : (
            <div class="border-t border-border/65 pt-8">
              <p class="text-[1.02rem] leading-8 text-foreground/66">
                {copy.anime.empty}
              </p>
              <p class="mt-2 text-sm leading-7 text-foreground/52">
                {copy.anime.emptyHelp}
              </p>
            </div>
          )
        }
  </main>

  <BackToTopButton {locale} />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const viewRoot = document.querySelector("[data-anime-view]");
    if (!(viewRoot instanceof HTMLElement)) return;

    const buttons = Array.from(
      document.querySelectorAll("[data-anime-toggle]")
    ).filter((node): node is HTMLButtonElement => node instanceof HTMLButtonElement);

    if (!buttons.length) return;

    const setView = (value: string) => {
      viewRoot.dataset.animeView = value;
      buttons.forEach(button => {
        const isActive = button.dataset.animeToggle === value;
        button.setAttribute("aria-pressed", String(isActive));
      });
    };

    buttons.forEach(button => {
      button.addEventListener("click", () => {
        const value = button.dataset.animeToggle;
        if (!value) return;
        setView(value);
      });
    });
  });
</script>

<style>
  .anime-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem 1.25rem;
    margin-top: 1.25rem;
    color: color-mix(in srgb, var(--foreground) 58%, transparent);
    font-size: 0.92rem;
    line-height: 1.7;
  }

  .anime-meta div {
    display: inline-flex;
    gap: 0.45rem;
    align-items: baseline;
  }

  .anime-meta dt {
    color: color-mix(in srgb, var(--foreground) 36%, transparent);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .anime-meta dd {
    margin: 0;
  }

  .anime-view {
    margin-top: 1.4rem;
  }

  .anime-view [data-anime-pane] {
    display: none;
  }

  .anime-view[data-anime-view="all"] [data-anime-pane="all"],
  .anime-view[data-anime-view="year"] [data-anime-pane="year"] {
    display: block;
  }

  .anime-archive--year {
    display: grid;
    gap: 2.4rem;
  }

  .anime-year-section {
    border-top: 1px solid color-mix(in srgb, var(--border) 68%, transparent);
    padding-top: 1.2rem;
  }

  .anime-year-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.9rem;
  }

  .anime-year-heading h2 {
    font-family: var(--font-ui-serif);
    font-size: 1.65rem;
    font-weight: 600;
    line-height: 1;
  }

  .anime-year-heading p {
    color: color-mix(in srgb, var(--foreground) 44%, transparent);
    font-size: 0.88rem;
  }


  @media (max-width: 639px) {
    .anime-header {
      margin-bottom: 2rem;
    }

    .anime-header h1 {
      font-size: 2.15rem;
      line-height: 1.08;
    }

    .anime-meta {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.7rem 0.9rem;
      margin-top: 1rem;
      font-size: 0.84rem;
      line-height: 1.55;
    }

    .anime-meta div {
      display: block;
      min-width: 0;
    }

    .anime-meta div:nth-child(4) {
      grid-column: 1 / -1;
    }

    .anime-meta dt {
      margin-bottom: 0.1rem;
      font-size: 0.66rem;
      letter-spacing: 0.12em;
    }

    .anime-meta dd {
      overflow-wrap: anywhere;
    }

    .anime-view-toggle {
      width: 100%;
      justify-content: flex-start;
      flex-wrap: wrap;
    }

    .anime-archive--year {
      gap: 2rem;
    }

    .anime-year-heading h2 {
      font-size: 1.45rem;
    }

    .anime-year-heading p {
      font-size: 0.8rem;
    }
  }
</style>
