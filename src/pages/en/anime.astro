---
import BackToTopButton from "@/components/BackToTopButton.astro";
import Footer from "@/components/Footer.astro";
import SiteTopbar from "@/components/SiteTopbar.astro";
import Layout from "@/layouts/Layout.astro";
import animeData from "@/data/anime.generated.json";
import type { AnimeDataPayload, AnimeItem } from "@/types/anime";
import { getDateLocale, ui } from "@/i18n";

const locale = "en";
const copy = ui[locale];
const data = animeData as AnimeDataPayload;

function getEntryKey(entry: AnimeItem) {
  return (
    entry.url || [entry.title.trim(), entry.cover, entry.year ?? ""].join("::")
  );
}

function normalizeItems(items: AnimeItem[]) {
  const seen = new Set<string>();
  const list: AnimeItem[] = [];

  for (const item of items ?? []) {
    const key = getEntryKey(item);
    if (!item?.title || !item?.cover || !item?.url || seen.has(key)) continue;
    seen.add(key);
    list.push(item);
  }

  return list;
}

function groupItems(items: AnimeItem[]) {
  const groups = new Map<string, AnimeItem[]>();

  for (const item of items ?? []) {
    const yearLabel = item.year ? String(item.year) : copy.anime.unknownYear;
    const list = groups.get(yearLabel);

    if (list) list.push(item);
    else groups.set(yearLabel, [item]);
  }

  return Array.from(groups.entries())
    .sort((a, b) => Number(b[0] || 0) - Number(a[0] || 0))
    .map(([yearLabel, entries]) => ({
      yearLabel,
      entries,
    }));
}

const entries = normalizeItems(data.items ?? []);
const groups = groupItems(entries);
const total = entries.length;
const pageTitle = copy.pages.animeFullTitle;
const pageDescription = copy.pages.animeDesc;
const sourceHref = data.username
  ? `https://anilist.co/user/${data.username}`
  : "https://anilist.co";

const updatedLabel = data.updatedAt
  ? new Intl.DateTimeFormat(getDateLocale(locale), {
      year: "numeric",
      month: "2-digit",
      day: "2-digit",
      hour: "2-digit",
      minute: "2-digit",
      hour12: false,
      timeZone: "Asia/Shanghai",
    }).format(new Date(data.updatedAt))
  : null;
---

<Layout
  title={pageTitle}
  description={pageDescription}
  structuredDataType="CollectionPage"
  structuredData={{
    mainEntity: {
      "@type": "ItemList",
      name: copy.anime.itemListName,
      numberOfItems: total,
    },
    about: "AniList completed anime collection filtered by custom list normal.",
  }}
  {locale}
>
  <SiteTopbar />

  <main class="app-layout pb-14 lg:max-w-7xl lg:pb-18" data-pagefind-body>
    <section class="px-1 pt-5 sm:px-2 sm:pt-7">
      <div>
        <header class="anime-header mb-10 max-w-4xl sm:mb-12">
          <p
            class="text-[0.76rem] font-medium tracking-[0.2em] text-foreground/36 uppercase"
          >
            {copy.pages.animeEyebrow}
          </p>
          <h1
            class="mt-2 [font-family:var(--font-ui-serif)] text-[2.3rem] leading-none font-semibold tracking-tight text-foreground sm:text-[2.8rem]"
          >
            {copy.pages.animeTitle}
          </h1>
          <dl class="anime-meta">
            <div>
              <dt>Total</dt>
              <dd>{total} {copy.anime.countUnit}</dd>
            </div>
            <div>
              <dt>{copy.anime.dataFrom}</dt>
              <dd>
                <a
                  href={sourceHref}
                  target="_blank"
                  rel="noreferrer"
                  class="text-accent underline decoration-accent/35 underline-offset-4"
                >
                  AniList{data.username ? ` / ${data.username}` : ""}
                </a>
              </dd>
            </div>
            <div>
              <dt>List</dt>
              <dd>normal / completed</dd>
            </div>
            {
              updatedLabel && (
                <div>
                  <dt>{copy.anime.updatedAt}</dt>
                  <dd>{updatedLabel}</dd>
                </div>
              )
            }
          </dl>
          <div class="anime-view-toggle" role="tablist" aria-label={copy.anime.viewMode}>
            <button
              type="button"
              class="is-active"
              data-anime-toggle="all"
              aria-pressed="true"
            >
              {copy.anime.viewAll}
            </button>
            <button
              type="button"
              data-anime-toggle="year"
              aria-pressed="false"
            >
              {copy.anime.viewByYear}
            </button>
          </div>
        </header>

        {
          entries.length > 0 ? (
            <div class="anime-view" data-anime-view="all">
              <div class="anime-archive anime-archive--all" data-anime-pane="all">
                <div class="anime-list">
                  {entries.map(entry => (
                    <a
                      href={entry.url}
                      target="_blank"
                      rel="noreferrer"
                      class="anime-card group"
                    >
                      <div class="anime-card__cover">
                        <img
                          src={entry.cover}
                          alt={`${entry.title} cover`}
                          loading="lazy"
                        />
                      </div>

                      <div class="anime-card__body">
                        <h3>{entry.title}</h3>
                        <p class="anime-card__meta">
                          {entry.year ? entry.year : copy.anime.unknownYear}
                        </p>
                      </div>
                    </a>
                  ))}
                </div>
              </div>

              <div class="anime-archive anime-archive--year" data-anime-pane="year">
                {groups.map(group => (
                  <section class="anime-year-section">
                    <div class="anime-year-heading">
                      <h2>{group.yearLabel}</h2>
                      <p>
                        {group.entries.length} {copy.anime.countUnit}
                      </p>
                    </div>

                    <div class="anime-list">
                      {group.entries.map(entry => (
                        <a
                          href={entry.url}
                          target="_blank"
                          rel="noreferrer"
                          class="anime-card group"
                        >
                          <div class="anime-card__cover">
                            <img
                              src={entry.cover}
                              alt={`${entry.title} cover`}
                              loading="lazy"
                            />
                          </div>

                          <div class="anime-card__body">
                            <h3>{entry.title}</h3>
                            <p class="anime-card__meta">
                              {entry.year ? entry.year : copy.anime.unknownYear}
                            </p>
                          </div>
                        </a>
                      ))}
                    </div>
                  </section>
                ))}
              </div>
            </div>
          ) : (
            <div class="border-t border-border/65 pt-8">
              <p class="text-[1.02rem] leading-8 text-foreground/66">
                {copy.anime.empty}
              </p>
              <p class="mt-2 text-sm leading-7 text-foreground/52">
                {copy.anime.emptyHelp}
              </p>
            </div>
          )
        }
      </div>
    </section>
  </main>

  <BackToTopButton {locale} />
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const viewRoot = document.querySelector("[data-anime-view]");
    if (!(viewRoot instanceof HTMLElement)) return;

    const buttons = Array.from(
      document.querySelectorAll("[data-anime-toggle]")
    ).filter((node): node is HTMLButtonElement => node instanceof HTMLButtonElement);

    if (!buttons.length) return;

    const setView = (value: string) => {
      viewRoot.dataset.animeView = value;
      buttons.forEach(button => {
        const isActive = button.dataset.animeToggle === value;
        button.classList.toggle("is-active", isActive);
        button.setAttribute("aria-pressed", String(isActive));
      });
    };

    buttons.forEach(button => {
      button.addEventListener("click", () => {
        const value = button.dataset.animeToggle;
        if (!value) return;
        setView(value);
      });
    });
  });
</script>

<style>
  .anime-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem 1.25rem;
    margin-top: 1.25rem;
    color: color-mix(in srgb, var(--foreground) 58%, transparent);
    font-size: 0.92rem;
    line-height: 1.7;
  }

  .anime-meta div {
    display: inline-flex;
    gap: 0.45rem;
    align-items: baseline;
  }

  .anime-meta dt {
    color: color-mix(in srgb, var(--foreground) 36%, transparent);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .anime-meta dd {
    margin: 0;
  }

  .anime-view-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.2rem;
  }

  .anime-view-toggle button {
    border: 1px solid color-mix(in srgb, var(--border) 72%, transparent);
    border-radius: 0.45rem;
    background: color-mix(in srgb, var(--background) 92%, transparent);
    padding: 0.35rem 0.95rem;
    color: color-mix(in srgb, var(--foreground) 62%, transparent);
    font-size: 0.84rem;
    font-weight: 500;
    transition:
      border-color 160ms ease,
      color 160ms ease,
      background-color 160ms ease;
  }

  .anime-view-toggle button.is-active {
    border-color: color-mix(in srgb, var(--accent) 55%, transparent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent);
  }

  .anime-view {
    margin-top: 1.4rem;
  }

  .anime-view [data-anime-pane] {
    display: none;
  }

  .anime-view[data-anime-view="all"] [data-anime-pane="all"],
  .anime-view[data-anime-view="year"] [data-anime-pane="year"] {
    display: block;
  }

  .anime-archive--year {
    display: grid;
    gap: 2.4rem;
  }

  .anime-year-section {
    border-top: 1px solid color-mix(in srgb, var(--border) 68%, transparent);
    padding-top: 1.2rem;
  }

  .anime-year-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.9rem;
  }

  .anime-year-heading h2 {
    font-family: var(--font-ui-serif);
    font-size: 1.65rem;
    font-weight: 600;
    line-height: 1;
  }

  .anime-year-heading p {
    color: color-mix(in srgb, var(--foreground) 44%, transparent);
    font-size: 0.88rem;
  }

  .anime-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(18.5rem, 1fr));
    gap: 1rem;
  }

  .anime-card {
    display: flex;
    min-width: 0;
    gap: 0.9rem;
    border: 1px solid color-mix(in srgb, var(--border) 78%, transparent);
    border-radius: 0.8rem;
    background: color-mix(in srgb, var(--background) 96%, transparent);
    padding: 0.75rem;
    color: var(--foreground);
    transition:
      border-color 160ms ease,
      background-color 160ms ease,
      box-shadow 160ms ease;
  }

  .anime-card:hover {
    border-color: color-mix(in srgb, var(--accent) 24%, var(--border));
    box-shadow: 0 10px 18px rgba(15, 23, 42, 0.08);
  }

  .anime-card__cover {
    width: 5.2rem;
    flex: none;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--border) 62%, transparent);
    border-radius: 0.6rem;
    background: var(--muted);
    aspect-ratio: 2 / 3;
  }

  .anime-card__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .anime-card__body {
    display: flex;
    min-width: 0;
    flex: 1;
    flex-direction: column;
    gap: 0.35rem;
    padding-top: 0.1rem;
  }

  .anime-card__body h3 {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    color: color-mix(in srgb, var(--foreground) 82%, transparent);
    font-size: 0.98rem;
    font-weight: 600;
    line-height: 1.5;
    -webkit-line-clamp: 2;
  }

  .anime-card__meta {
    color: color-mix(in srgb, var(--foreground) 48%, transparent);
    font-size: 0.82rem;
  }


  @media (max-width: 639px) {
    .anime-header {
      margin-bottom: 2rem;
    }

    .anime-header h1 {
      font-size: 2.15rem;
      line-height: 1.08;
    }

    .anime-meta {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.7rem 0.9rem;
      margin-top: 1rem;
      font-size: 0.84rem;
      line-height: 1.55;
    }

    .anime-meta div {
      display: block;
      min-width: 0;
    }

    .anime-meta div:nth-child(4) {
      grid-column: 1 / -1;
    }

    .anime-meta dt {
      margin-bottom: 0.1rem;
      font-size: 0.66rem;
      letter-spacing: 0.12em;
    }

    .anime-meta dd {
      overflow-wrap: anywhere;
    }

    .anime-view-toggle {
      width: 100%;
      justify-content: flex-start;
      flex-wrap: wrap;
    }

    .anime-archive--year {
      gap: 2rem;
    }

    .anime-year-heading h2 {
      font-size: 1.45rem;
    }

    .anime-year-heading p {
      font-size: 0.8rem;
    }

    .anime-list {
      grid-template-columns: 1fr;
      gap: 0.85rem;
    }

    .anime-card {
      padding: 0.7rem;
    }

    .anime-card__cover {
      width: 4.7rem;
    }

    .anime-card__body h3 {
      font-size: 0.92rem;
    }
  }

  @media (max-width: 374px) {
    .anime-card__cover {
      width: 4.4rem;
    }

    .anime-card__body h3 {
      font-size: 0.88rem;
    }
  }
</style>
