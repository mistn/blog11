---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Footer from "@/components/Footer.astro";
import SiteTopbar from "@/components/SiteTopbar.astro";
import Datetime from "@/components/Datetime.astro";
import PageSidebar from "@/components/PageSidebar.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import { SITE } from "@/config";
import { localizePath, ui } from "@/i18n";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return paginate(getSortedPosts(posts), { pageSize: SITE.postPerPage });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const locale = "en";
const copy = ui[locale];
const posts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = getSortedPosts(posts);
const listPosts = page.data;
const hasNextPage = page.currentPage < page.lastPage;

function getPageHref(pageNumber: number) {
  if (pageNumber === 1) return localizePath("/", locale);
  return localizePath(`/posts/${pageNumber}`, locale);
}
---

<Layout title={`${copy.pages.postsTitle} | ${SITE.title}`} {locale}>
  <SiteTopbar />
  <main
    id="main-content"
    data-layout="index"
    data-post-memory-scope="list"
    class="app-layout pb-10 lg:max-w-7xl lg:pb-14"
  >
    <section class="overflow-hidden">
      <div class="px-1 py-4 sm:px-2 sm:py-5">
        <div class="grid gap-10 lg:grid-cols-[minmax(0,1.78fr)_260px]">
          <div class="min-w-0">
            <div class="divide-y divide-border/55" data-post-list>
              {
                listPosts.map(post => (
                  <article class="py-10" data-post-item>
                    <a
                      href={localizePath(getPath(post.id, post.filePath), locale)}
                      data-post-link
                      class="card-link-press inline-block text-[1.8rem] leading-[1.22] font-medium tracking-tight transition hover:text-accent sm:text-[2rem]"
                    >
                      {post.data.title}
                    </a>
                    <Datetime
                      {...post.data}
                      {locale}
                      class="mt-3.5 text-foreground/52 [&_svg]:scale-75 [&_svg]:opacity-70"
                    />
                    <p class="mt-4 max-w-3xl text-[1.06rem] leading-[1.9] text-foreground/74">
                      {post.data.description}
                    </p>
                  </article>
                ))
              }
            </div>

            {hasNextPage && (
              <nav
                class="page-number-nav"
                aria-label="Pagination Navigation"
              >
                <a
                  href={getPageHref(page.currentPage + 1)}
                  class="post-continuation-link"
                  data-load-more
                >
                  Load more
                </a>
              </nav>
            )}
          </div>

          <PageSidebar posts={sortedPosts} {locale} />
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const loadMoreLink = document.querySelector(
      "[data-load-more]"
    ) as HTMLAnchorElement | null;
    const postList = document.querySelector(
      "[data-post-list]"
    ) as HTMLElement | null;

    if (!loadMoreLink || !postList) return;

    let isLoading = false;
    const onLoadMore = async () => {
      if (isLoading) return;
      const nextUrl = loadMoreLink.getAttribute("href");
      if (!nextUrl) return;

      isLoading = true;
      loadMoreLink.setAttribute("aria-busy", "true");

      try {
        const response = await fetch(nextUrl);
        if (!response.ok) throw new Error("Failed to load next page");
        const html = await response.text();
        const doc = new DOMParser().parseFromString(html, "text/html");
        const nextList = doc.querySelector("[data-post-list]");
        const nextLink = doc.querySelector(
          "[data-load-more]"
        ) as HTMLAnchorElement | null;

        if (nextList) {
          nextList
            .querySelectorAll("[data-post-item]")
            .forEach((item) => postList.appendChild(item));
        }

        if (nextLink?.getAttribute("href")) {
          loadMoreLink.setAttribute("href", nextLink.getAttribute("href")!);
        } else {
          loadMoreLink.remove();
        }
      } catch (error) {
        // noop
      } finally {
        loadMoreLink.removeAttribute("aria-busy");
        isLoading = false;
      }
    };

    loadMoreLink.addEventListener("click", (event) => {
      const isModifier =
        event.metaKey || event.ctrlKey || event.shiftKey || event.altKey;
      if (isModifier || event.button !== 0) return;
      event.preventDefault();
      onLoadMore();
    });

  });
</script>
