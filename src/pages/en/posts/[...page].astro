---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import SiteTopbar from "@/components/SiteTopbar.astro";
import Datetime from "@/components/Datetime.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import { SITE } from "@/config";
import { localizePath, ui } from "@/i18n";
import { getReadingStats } from "@/utils/readingTime";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return paginate(getSortedPosts(posts), { pageSize: SITE.postPerPage });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const locale = "en";
const copy = ui[locale];
const listPosts = page.data;
const pageNumbers = Array.from(
  { length: page.lastPage },
  (_, index) => index + 1
);

function getPageHref(pageNumber: number) {
  if (pageNumber === 1) return localizePath("/", locale);
  return localizePath(`/posts/${pageNumber}`, locale);
}
---

<Layout title={`${copy.pages.postsTitle} | ${SITE.title}`} {locale}>
  <SiteTopbar />
  <main
    id="main-content"
    data-layout="index"
    data-post-memory-scope="list"
    class="mx-auto w-full max-w-5xl px-4 pt-6 pb-10 md:pt-10 md:pb-14"
  >
    <section class="overflow-hidden">
      <div class="px-1 py-2 sm:px-2 md:py-5">
        <div>
          <div class="min-w-0">
            <div data-post-list>
              {
                listPosts.map(post => {
                  const stats = getReadingStats(post.body || "");
                  return (
                  <article class="py-6 md:py-10" data-post-item>
                    <a
                      href={localizePath(getPath(post.id, post.filePath), locale)}
                      data-post-link
                      class="card-link-press inline-block text-[1.45rem] leading-tight font-medium tracking-tight transition hover:text-accent active:opacity-60"
                    >
                      {post.data.title}
                    </a>
                    <div class="mt-2.5 md:mt-3.5 flex flex-wrap items-center gap-2.5 text-xs text-foreground/52 [&_svg]:scale-75 [&_svg]:opacity-70">
                      <Datetime {...post.data} {locale} class="" />
                      <span class="inline-flex items-center gap-1">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                        {stats.readingTime}m
                      </span>
                    </div>
                    <p class="mt-3 md:mt-4 max-w-3xl text-sm leading-relaxed text-gray-600 dark:text-gray-400 md:text-base line-clamp-2">
                      {post.data.description}
                    </p>
                  </article>
                  );
                })
              }
            </div>

            {page.lastPage > 1 && (
              <nav class="mt-6 md:mt-12 flex justify-center items-center gap-6" aria-label="Pagination Navigation">
                {pageNumbers.map(pageNumber => (
                  <a
                    href={getPageHref(pageNumber)}
                    class={
                      pageNumber === page.currentPage
                        ? "text-gray-800 dark:text-gray-200 font-semibold text-base"
                        : "text-gray-400 dark:text-gray-500 hover:text-gray-900 dark:hover:text-gray-100 transition-colors text-base"
                    }
                    aria-current={
                      pageNumber === page.currentPage ? "page" : undefined
                    }
                  >
                    {pageNumber}
                  </a>
                ))}
              </nav>
            )}
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    sessionStorage.setItem("backUrl", window.location.pathname);
  });
</script>
