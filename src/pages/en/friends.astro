---
import SiteTopbar from "@/components/SiteTopbar.astro";
import ArtalkComments from "@/components/ArtalkComments.astro";
import Layout from "@/layouts/Layout.astro";
import { defaultFriendAvatar, friendLinks, siteProfile } from "@/data/friends";
import { SITE } from "@/config";
import { ui } from "@/i18n";

const locale = "en";
const copy = ui[locale];
const applicationFields = [
  { label: "name", value: "miuo's blog" },
  { label: "url", value: siteProfile.href },
  { label: "avatar", value: siteProfile.avatar },
  { label: "desc", value: siteProfile.description },
  { label: "email", value: "hi@miuo.me" },
];
const applicationText = applicationFields
  .map(field => `${field.label}: ${field.value}`)
  .join("\n");
---

<Layout
  title={`${copy.pages.friendsTitle} | ${SITE.title}`}
  description={copy.pages.friendsDesc}
  structuredDataType="CollectionPage"
  structuredData={{
    mainEntity: {
      "@type": "ItemList",
      name: copy.pages.friendsTitle,
      numberOfItems: friendLinks.length,
    },
  }}
  {locale}
>
  <SiteTopbar />

  <main id="main-content" class="app-layout pb-14 lg:max-w-5xl">
    <section class="px-1 py-4 sm:px-2 sm:py-5" data-pagefind-body>
      <header class="mb-10 max-w-4xl">
        <p
          class="text-[0.76rem] font-medium tracking-[0.2em] text-foreground/36 uppercase"
        >
          {copy.pages.friendsEyebrow}
        </p>
        <h1
          class="mt-2 text-[2.2rem] leading-[1.12] font-medium tracking-tight sm:text-[2.6rem]"
        >
          {copy.pages.friendsTitle}
        </h1>
        <p class="mt-4 max-w-3xl text-[1rem] leading-8 text-foreground/60">
          {copy.pages.friendsDesc}
        </p>
      </header>

      <div class="max-w-4xl">
        <section>
          {
            friendLinks.length > 0 ? (
              <div class="friend-grid">
                {friendLinks.map(friend => (
                  <a
                    href={friend.href}
                    target="_blank"
                    rel="noreferrer"
                    class="friend-card group"
                    style={{ "--friend-accent": friend.color ?? "var(--accent)" }}
                  >
                    <img
                      src={friend.avatar ?? defaultFriendAvatar}
                      alt={`${friend.name} avatar`}
                      class="friend-card__avatar"
                      loading="lazy"
                    />
                    <div class="friend-card__body">
                      <div class="friend-card__title-row">
                        <h2>{friend.blog ?? friend.name}</h2>
                        <span class="friend-card__arrow" aria-hidden="true">↗</span>
                      </div>
                      {
                        friend.blog && friend.blog !== friend.name && (
                          <p class="friend-card__name">{friend.name}</p>
                        )
                      }
                      <p class="friend-card__desc">{friend.description}</p>
                      <span class="friend-card__link">{friend.href}</span>
                    </div>
                  </a>
                ))}
              </div>
            ) : (
              <div class="border-y border-border/65 py-8">
                <p class="text-[1.05rem] leading-8 text-foreground/68">
                  No friend links yet. Exchanged links will be listed here.
                </p>
              </div>
            )
          }
        </section>

        <section class="apply-section">
          <div>
            <p class="section-eyebrow">Apply</p>
            <h2>Friend Link Format</h2>
            <p>
              Leave a comment below in this format to exchange links. Existing
              friends can also comment if their information needs an update.
            </p>
          </div>

          <div class="friend-application mt-6">
            <p class="friend-application-title">Template</p>
            <div class="code-block-frame">
              <div class="code-block-header">
                <div class="code-block-meta">
                  <svg aria-hidden="true" class="code-block-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m8 9-3 3 3 3"></path>
                    <path d="m16 9 3 3-3 3"></path>
                    <path d="m14 5-4 14"></path>
                  </svg>
                  <span class="code-language-badge">YAML</span>
                </div>
                <div class="code-block-actions">
                  <button class="code-block-action" type="button" data-copy-value={applicationText} aria-label="Copy template">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <path d="M9 9H5a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      <rect x="9" y="3" width="11" height="11" rx="2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span class="sr-only">Copy template</span>
                  </button>
                </div>
              </div>
              <dl class="friend-application__list">
                {
                  applicationFields.map(field => (
                    <div class="friend-application__item">
                      <dt>{field.label}</dt>
                      <dd>{field.value}</dd>
                    </div>
                  ))
                }
              </dl>
            </div>
          </div>
        </section>
      </div>

      <div class="max-w-4xl">
        <ArtalkComments pageKey="/en/friends" pageTitle={copy.pages.friendsTitle} />
      </div>
    </section>
  </main>

</Layout>

<script is:inline data-astro-rerun>
  const COPY_TEXT = "Copy";
  const COPIED_TEXT = "Copied";
  const COPY_FAILED_TEXT = "Copy failed";

  const getCopyButtonContent = (label, copied = false) => {
    const icon = copied
      ? `<path d="m5 12 4 4L19 6"></path>`
      : `<rect x="9" y="9" width="11" height="11" rx="2"></rect>
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>`;

    return `
      <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        ${icon}
      </svg>
      <span class="sr-only">${label}</span>
    `;
  };

  const setupCopyButtons = () => {
    const buttons = document.querySelectorAll("[data-copy-value]");
    buttons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;
      if (button.dataset.copyBound === "true") return;
      button.dataset.copyBound = "true";
      button.innerHTML = getCopyButtonContent(COPY_TEXT);
      button.ariaLabel = COPY_TEXT;
      button.title = COPY_TEXT;

      button.addEventListener("click", async () => {
        const value = button.dataset.copyValue;
        if (!value) return;

        try {
          await navigator.clipboard.writeText(value);
          button.innerHTML = getCopyButtonContent(COPIED_TEXT, true);
          button.ariaLabel = COPIED_TEXT;
          button.title = COPIED_TEXT;
          window.setTimeout(() => {
            button.innerHTML = getCopyButtonContent(COPY_TEXT);
            button.ariaLabel = COPY_TEXT;
            button.title = COPY_TEXT;
          }, 900);
        } catch {
          const originalText = button.textContent ?? COPY_TEXT;
          button.textContent = COPY_FAILED_TEXT;
          window.setTimeout(() => {
            button.textContent = originalText;
          }, 1400);
        }
      });
    });
  };

  document.addEventListener("astro:page-load", setupCopyButtons);
  document.addEventListener("astro:after-swap", setupCopyButtons);
  setupCopyButtons();
</script>

<style>
  .friend-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 19rem), 1fr));
    gap: 1rem;
  }

  .friend-card {
    position: relative;
    display: flex;
    min-width: 0;
    min-height: 8rem;
    align-items: flex-start;
    gap: 1rem;
    border: 1px solid color-mix(in srgb, var(--border) 82%, transparent);
    border-radius: 0.8rem;
    background: color-mix(in srgb, var(--background) 98%, transparent);
    padding: 1rem;
    color: var(--foreground);
    box-shadow: 0 6px 16px rgba(15, 23, 42, 0.04);
    transition:
      border-color 160ms ease,
      color 160ms ease,
      background-color 160ms ease,
      box-shadow 160ms ease;
  }

  .friend-card:hover {
    border-color: color-mix(in srgb, var(--friend-accent) 24%, var(--border));
    background: color-mix(in srgb, var(--background) 96%, transparent);
    box-shadow: 0 7px 18px rgba(15, 23, 42, 0.05);
  }

  .friend-card__avatar {
    width: 3.2rem;
    height: 3.2rem;
    flex: none;
    border: 1px solid color-mix(in srgb, var(--border) 72%, transparent);
    border-radius: 999px;
    object-fit: cover;
  }

  .friend-card__body {
    display: flex;
    min-height: 100%;
    min-width: 0;
    flex: 1;
    flex-direction: column;
  }

  .friend-card__title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.65rem;
  }

  .friend-card__body h2 {
    overflow: hidden;
    font-family: var(--font-ui-serif);
    font-size: 1.06rem;
    font-weight: 600;
    line-height: 1.25;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .friend-card__arrow {
    flex: none;
    color: color-mix(in srgb, var(--foreground) 46%, transparent);
    font-size: 0.9rem;
    transition:
      color 160ms ease;
  }

  .friend-card:hover .friend-card__arrow {
    color: color-mix(in srgb, var(--foreground) 58%, transparent);
  }

  .friend-card__name {
    margin-top: 0.14rem;
    color: color-mix(in srgb, var(--foreground) 46%, transparent);
    font-size: 0.75rem;
    line-height: 1.45;
  }

  .friend-card__desc {
    display: -webkit-box;
    margin-top: 0.4rem;
    overflow: hidden;
    -webkit-box-orient: vertical;
    color: color-mix(in srgb, var(--foreground) 66%, transparent);
    font-size: 0.84rem;
    line-height: 1.55;
    -webkit-line-clamp: 2;
    transition: color 160ms ease;
  }

  .friend-card:hover .friend-card__desc {
    color: color-mix(in srgb, var(--foreground) 76%, transparent);
  }

  .friend-card__link {
    display: block;
    margin-top: auto;
    padding-top: 0.45rem;
    overflow: hidden;
    color: color-mix(in srgb, var(--foreground) 44%, transparent);
    font-size: 0.75rem;
    line-height: 1.45;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: color 160ms ease;
  }

  .friend-card:hover .friend-card__link {
    color: color-mix(in srgb, var(--foreground) 62%, transparent);
  }

  .apply-section {
    margin-top: 2.6rem;
    border-top: 1px solid color-mix(in srgb, var(--border) 68%, transparent);
    padding-top: 2.6rem;
  }

  .section-eyebrow {
    color: color-mix(in srgb, var(--foreground) 36%, transparent);
    font-size: 0.76rem;
    font-weight: 500;
    letter-spacing: 0.32em;
    text-transform: uppercase;
  }

  .apply-section h2 {
    margin-top: 0.75rem;
    font-family: var(--font-ui-serif);
    font-size: 1.85rem;
    font-weight: 600;
    line-height: 1.18;
    letter-spacing: 0;
  }

  .apply-section p:not(.section-eyebrow) {
    max-width: 42rem;
    margin-top: 1rem;
    color: color-mix(in srgb, var(--foreground) 66%, transparent);
    font-size: 1rem;
    line-height: 2;
  }

  .friend-application {
    position: relative;
  }

  .friend-application-title {
    margin: 0 0 0.5rem;
    color: color-mix(in srgb, var(--foreground) 72%, transparent);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .friend-application .code-block-frame {
    position: relative;
    border: 1px solid color-mix(in srgb, var(--border) 65%, transparent);
    border-radius: 0.75rem;
    background: color-mix(in srgb, var(--background) 85%, transparent);
    box-shadow: 0 4px 12px rgba(15, 23, 42, 0.04);
  }

  .friend-application .code-block-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    height: 2.5rem;
    padding: 0 0.75rem;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 60%, transparent);
    background: color-mix(in srgb, var(--background) 85%, transparent);
  }

  .friend-application .code-block-meta {
    display: flex;
    min-width: 0;
    align-items: center;
    gap: 0.5rem;
  }

  .friend-application .code-block-icon {
    width: 1rem;
    height: 1rem;
    flex: none;
    color: color-mix(in srgb, var(--foreground) 72%, transparent);
  }

  .friend-application .code-language-badge {
    border-radius: 0.25rem;
    border: 1px solid color-mix(in srgb, var(--border) 80%, transparent);
    background: color-mix(in srgb, var(--muted) 55%, transparent);
    padding: 0.18rem 0.5rem;
    font-size: 0.7rem;
    line-height: 1;
    color: color-mix(in srgb, var(--foreground) 76%, transparent);
  }

  .friend-application .code-block-actions {
    display: flex;
    flex: none;
    align-items: center;
  }

  .friend-application .code-block-action {
    display: inline-flex;
    width: 1.75rem;
    height: 1.75rem;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    color: color-mix(in srgb, var(--foreground) 70%, transparent);
    transition: background-color 160ms ease, color 160ms ease;
  }

  .friend-application .code-block-action:hover {
    background: color-mix(in srgb, var(--background) 92%, transparent);
    color: color-mix(in srgb, var(--accent) 88%, transparent);
  }

  .friend-application .code-block-action svg {
    width: 0.9rem;
    height: 0.9rem;
  }

  .friend-application__list {
    margin: 0 1rem 1rem;
    padding: 0.3rem 0 0.2rem;
    overflow-x: auto;
    overflow-y: hidden;
  }

  .friend-application__item {
    display: flex;
    align-items: flex-start;
    gap: 0.25rem 0.5rem;
    padding: 0.45rem 0;
  }

  .friend-application__item + .friend-application__item {
    border-top: none;
  }

  .friend-application__item dt {
    margin: 0;
    color: color-mix(in srgb, var(--foreground) 52%, transparent);
    font-family: var(--font-ui-mono);
    font-size: 0.8rem;
    letter-spacing: 0.02em;
  }

  .friend-application__item dt::after {
    content: ":";
    margin-left: 0.2rem;
  }

  .friend-application__item dd {
    margin: 0;
    overflow-wrap: anywhere;
    color: color-mix(in srgb, var(--foreground) 78%, transparent);
    font-family: var(--font-ui-mono);
    font-size: 0.9rem;
    line-height: 1.65;
    white-space: nowrap;
  }

  .friend-application__item dt {
    flex: 0 0 4.4rem;
    min-width: 4.4rem;
  }

  .friend-application__item dd {
    flex: 1 1 auto;
    min-width: 0;
  }


  @media (max-width: 639px) {
    .friend-grid {
      gap: 0.7rem;
    }

    .friend-card {
      min-height: 7.4rem;
      gap: 0.78rem;
      border-radius: 0.75rem;
      padding: 0.86rem;
    }

    .friend-card__avatar {
      width: 2.9rem;
      height: 2.9rem;
    }

    .friend-card__body h2 {
      font-size: 1rem;
    }

    .friend-card__desc {
      -webkit-line-clamp: 1;
    }

    .apply-section {
      margin-top: 2rem;
      padding-top: 2rem;
    }

    .apply-section h2 {
      font-size: 1.55rem;
    }

    .friend-application-title {
      font-size: 0.82rem;
    }

    .friend-application .code-block-header {
      height: 2.35rem;
      padding: 0 0.7rem;
    }

    .friend-application__list {
      margin: 0.8rem 0.85rem 0.85rem;
      padding-left: 0.85rem;
    }

    .friend-application__item {
      padding: 0.3rem 0;
    }

    .friend-application__item dd {
      font-size: 0.82rem;
      line-height: 1.65;
    }
  }
</style>
