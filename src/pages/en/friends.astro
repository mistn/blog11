---
import SiteTopbar from "@/components/SiteTopbar.astro";
import ArtalkComments from "@/components/ArtalkComments.astro";
import PageHeader from "@/components/PageHeader.astro";
import Layout from "@/layouts/Layout.astro";
import { defaultFriendAvatar, friendLinks, siteProfile } from "@/data/friends";
import { SITE } from "@/config";
import { ui } from "@/i18n";

const locale = "en";
const copy = ui[locale];
const applicationFields = [
  { label: "name", value: "miuo's blog" },
  { label: "url", value: siteProfile.href },
  { label: "avatar", value: siteProfile.avatar },
  { label: "desc", value: siteProfile.description },
  { label: "email", value: "hi@miuo.me" },
];
const applicationText = applicationFields
  .map(field => `${field.label}: ${field.value}`)
  .join("\n");
---

<Layout
  title={`${copy.pages.friendsTitle} | ${SITE.title}`}
  description={copy.pages.friendsDesc}
  structuredDataType="CollectionPage"
  structuredData={{
    mainEntity: {
      "@type": "ItemList",
      name: copy.pages.friendsTitle,
      numberOfItems: friendLinks.length,
    },
  }}
  {locale}
>
  <SiteTopbar />

  <main id="main-content" class="mx-auto max-w-5xl px-4 pb-14">
    <PageHeader title={copy.pages.friendsTitle} />
    <section class="py-4" data-pagefind-body>
      <div class="max-w-5xl">
        <section>
          {
            friendLinks.length > 0 ? (
              <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 sm:gap-4">
                {friendLinks.map(friend => (
                  <a
                    href={friend.href}
                    target="_blank"
                    rel="noreferrer"
                    class="group relative flex min-h-32 items-start gap-4 rounded-2xl bg-muted/40 p-4 transition-all duration-300 hover:bg-background hover:shadow-[0_8px_30px_rgb(0,0,0,0.04)]"
                  >
                    <img
                      src={friend.avatar ?? defaultFriendAvatar}
                      alt={`${friend.name} avatar`}
                      class="h-12 w-12 flex-none rounded-full object-cover ring-1 ring-border/40"
                      loading="lazy"
                    />
                    <div class="flex min-w-0 flex-1 flex-col">
                      <div class="flex items-start justify-between gap-2">
                        <h2 class="truncate text-base font-semibold text-foreground">{friend.blog ?? friend.name}</h2>
                        <span class="flex-none translate-y-0.5 text-foreground/20 transition-all group-hover:translate-x-1 group-hover:-translate-y-1 group-hover:text-foreground/50" aria-hidden="true">↗</span>
                      </div>
                      {
                        friend.blog && friend.blog !== friend.name && (
                          <p class="mt-0.5 text-xs text-foreground/45">{friend.name}</p>
                        )
                      }
                      <p class="mt-1.5 line-clamp-2 text-sm leading-relaxed text-foreground/55">{friend.description}</p>
                    </div>
                  </a>
                ))}
              </div>
            ) : (
              <div class="border-y border-border/65 py-8">
                <p class="text-[1.05rem] leading-8 text-foreground/68">
                  No friend links yet. Exchanged links will be listed here.
                </p>
              </div>
            )
          }
        </section>

        <section class="apply-section">
          <div>
            <p class="section-eyebrow">Apply</p>
            <h2>Friend Link Format</h2>
            <p>
              Leave a comment below in this format to exchange links. Existing
              friends can also comment if their information needs an update.
            </p>
          </div>

          <div class="friend-application mt-6">
            <p class="friend-application-title">Template</p>
            <div class="relative rounded-xl bg-muted/40">
              <div class="flex items-center justify-between gap-3 rounded-t-xl px-4 py-2 text-sm text-foreground/45">
                <div class="flex min-w-0 items-center gap-2">
                  <svg aria-hidden="true" class="size-3.5 flex-none text-foreground/45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m8 9-3 3 3 3"></path>
                    <path d="m16 9 3 3-3 3"></path>
                    <path d="m14 5-4 14"></path>
                  </svg>
                  <span class="rounded-sm bg-muted/60 px-1.5 py-0.5 text-[0.68rem] leading-none font-normal text-foreground/50">YAML</span>
                </div>
                <div class="flex flex-none items-center gap-1">
                  <button class="inline-flex size-7 flex-none items-center justify-center rounded text-foreground/40 transition hover:text-foreground/70" type="button" data-copy-value={applicationText} aria-label="Copy template">
                    <svg class="size-3.5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <path d="M9 9H5a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      <rect x="9" y="3" width="11" height="11" rx="2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span class="sr-only">Copy template</span>
                  </button>
                </div>
              </div>
              <dl class="friend-application__list">
                {
                  applicationFields.map(field => (
                    <div class="friend-application__item">
                      <dt>{field.label}</dt>
                      <dd>{field.value}</dd>
                    </div>
                  ))
                }
              </dl>
            </div>
          </div>
        </section>
      </div>

      <div class="max-w-5xl">
        <ArtalkComments pageKey="/en/friends" pageTitle={copy.pages.friendsTitle} />
      </div>
    </section>
  </main>

</Layout>

<script is:inline data-astro-rerun>
  const COPY_TEXT = "Copy";
  const COPIED_TEXT = "Copied";
  const COPY_FAILED_TEXT = "Copy failed";

  const getCopyButtonContent = (label, copied = false) => {
    const icon = copied
      ? `<path d="m5 12 4 4L19 6"></path>`
      : `<rect x="9" y="9" width="11" height="11" rx="2"></rect>
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>`;

    return `
      <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        ${icon}
      </svg>
      <span class="sr-only">${label}</span>
    `;
  };

  const setupCopyButtons = () => {
    const buttons = document.querySelectorAll("[data-copy-value]");
    buttons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;
      if (button.dataset.copyBound === "true") return;
      button.dataset.copyBound = "true";
      button.innerHTML = getCopyButtonContent(COPY_TEXT);
      button.ariaLabel = COPY_TEXT;
      button.title = COPY_TEXT;

      button.addEventListener("click", async () => {
        const value = button.dataset.copyValue;
        if (!value) return;

        try {
          await navigator.clipboard.writeText(value);
          button.innerHTML = getCopyButtonContent(COPIED_TEXT, true);
          button.ariaLabel = COPIED_TEXT;
          button.title = COPIED_TEXT;
          window.setTimeout(() => {
            button.innerHTML = getCopyButtonContent(COPY_TEXT);
            button.ariaLabel = COPY_TEXT;
            button.title = COPY_TEXT;
          }, 900);
        } catch {
          const originalText = button.textContent ?? COPY_TEXT;
          button.textContent = COPY_FAILED_TEXT;
          window.setTimeout(() => {
            button.textContent = originalText;
          }, 1400);
        }
      });
    });
  };

  document.addEventListener("astro:page-load", setupCopyButtons);
  document.addEventListener("astro:after-swap", setupCopyButtons);
  setupCopyButtons();
</script>

<style>
  .apply-section {
    margin-top: 2.6rem;
    border-top: 1px solid color-mix(in srgb, var(--border) 68%, transparent);
    padding-top: 2.6rem;
  }

  .section-eyebrow {
    color: color-mix(in srgb, var(--foreground) 36%, transparent);
    font-size: 0.76rem;
    font-weight: 500;
    letter-spacing: 0.32em;
    text-transform: uppercase;
  }

  .apply-section h2 {
    margin-top: 0.75rem;
    font-size: 1.85rem;
    font-weight: 600;
    line-height: 1.18;
  }

  .apply-section p:not(.section-eyebrow) {
    max-width: 42rem;
    margin-top: 1rem;
    color: color-mix(in srgb, var(--foreground) 66%, transparent);
    font-size: 1rem;
    line-height: 2;
  }

  .friend-application {
    position: relative;
  }

  .friend-application-title {
    margin: 0 0 0.5rem;
    color: color-mix(in srgb, var(--foreground) 72%, transparent);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .friend-application__list {
    margin: 0 1rem 1rem;
    padding: 0.3rem 0 0.2rem;
    overflow-x: auto;
    overflow-y: hidden;
  }

  .friend-application__item {
    display: flex;
    align-items: flex-start;
    gap: 0.25rem 0.5rem;
    padding: 0.45rem 0;
  }

  .friend-application__item dt {
    margin: 0;
    color: color-mix(in srgb, var(--foreground) 52%, transparent);
    font-size: 0.88rem;
  }

  .friend-application__item dt::after {
    content: ":";
    margin-left: 0.2rem;
  }

  .friend-application__item dd {
    margin: 0;
    overflow-wrap: anywhere;
    color: color-mix(in srgb, var(--foreground) 78%, transparent);
    font-size: 0.98rem;
    line-height: 1.7;
    white-space: nowrap;
  }

  .friend-application__item dt {
    flex: 0 0 4.4rem;
    min-width: 4.4rem;
  }

  .friend-application__item dd {
    flex: 1 1 auto;
    min-width: 0;
  }


  @media (max-width: 639px) {
    .apply-section {
      margin-top: 2rem;
      padding-top: 2rem;
    }

    .apply-section h2 {
      font-size: 1.55rem;
    }

    .friend-application-title {
      font-size: 0.82rem;
    }

    .friend-application__list {
      margin: 0.8rem 0.85rem 0.85rem;
      padding-left: 0.85rem;
    }

    .friend-application__item {
      padding: 0.3rem 0;
    }

    .friend-application__item dd {
      font-size: 0.82rem;
      line-height: 1.65;
    }
  }
</style>
