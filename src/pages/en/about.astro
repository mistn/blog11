---
import SiteTopbar from "@/components/SiteTopbar.astro";
import Layout from "@/layouts/Layout.astro";
import PageHeader from "@/components/PageHeader.astro";
import { SITE } from "@/config";
import { ui } from "@/i18n";

const locale = "en";
const copy = ui[locale];
---

<Layout title={`${copy.pages.aboutTitle} | ${SITE.title}`} {locale}>
  <SiteTopbar />
  <main id="main-content" class="mx-auto max-w-4xl px-4 pb-14">
    <PageHeader title={copy.pages.aboutTitle} />
    <section
      id="about"
      class="app-prose prose-img:border-0 prose-p:font-normal prose-p:text-gray-600 prose-p:leading-relaxed prose-li:font-normal prose-li:text-gray-600"
    >
      <p>This is miuo's personal site.</p>

      <p>
        It mainly keeps things worth coming back to: essays, notes,
        configuration records, deployment logs, and the occasional experiment.
      </p>

      <p>
        Not every piece is exhaustive, but I try to keep the writing clear,
        reviewable, and useful for future me.
      </p>

      <h2>About This Site</h2>

      <ul>
        <li>Documenting setup processes and real usage experience</li>
        <li>Keeping notes I may need again later</li>
        <li>
          Organising input methods, tools, deployment, and productivity notes
        </li>
      </ul>

      <p>If something here is useful to you too, even better.</p>

      <h2>Contact</h2>

      <ul>
        <li>
          Email: <a href="mailto:hi@miuo.me">hi@miuo.me</a>
        </li>
      </ul>

      <h2>Source Code</h2>

      <p>
        This site is open source on
        <a href="https://github.com/mistn/blog11">GitHub</a>, built on a
        heavily customised AstroPaper theme.
      </p>
    </section>
  </main>
</Layout>
