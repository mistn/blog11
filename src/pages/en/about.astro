---
import SiteTopbar from "@/components/SiteTopbar.astro";
import Layout from "@/layouts/Layout.astro";
import PageHeader from "@/components/PageHeader.astro";
import { SITE } from "@/config";
import { ui } from "@/i18n";

const locale = "en";
const copy = ui[locale];
---

<Layout title={`${copy.pages.aboutTitle} | ${SITE.title}`} {locale}>
  <SiteTopbar />
  <main id="main-content" class="mx-auto w-full max-w-4xl px-4 pt-8 pb-10 md:pt-12 md:pb-14">
    <PageHeader title={copy.pages.aboutTitle} />
    <section
      id="about"
      class="app-prose prose-img:border-0"
    >
      <p>This is miuo's digital garden.</p>

      <p>
        Mostly technical notes, tinkering logs, and personal workflow setups.
        Written as reminders for myself. If something here happens to help you
        too, all the better. Source on <a href="https://github.com/mistn/blog11">GitHub</a>.
      </p>

      <h2>Lab</h2>

      <p>Self-hosted services running in the cloud.</p>

      <ul>
        <li>
          <a href="https://spotify.miuo.me/?gname=All&token=19b6fb61-e46f-483c-8514-2aab0f51b579">
            Listening Record
          </a> — what I'm listening to
        </li>
        <li><a href="https://img.2731515.xyz">Wallpaper API</a> — random wallpapers</li>
        <li><a href="https://api.2731515.xyz">Image Host</a> — personal image host</li>
        <li><a href="https://mail.2731515.xyz">Temp Mail</a> — disposable inbox</li>
        <li>
          <a href="https://stats.uptimerobot.com/tyYiHJaRpS">Status Monitor</a>
          — service uptime
        </li>
        <li>
          <a href="https://ss.miuo.me">Server Probe</a>
          — server health check
        </li>
      </ul>

      <h2>Contact</h2>

      <ul>
        <li>Email: hi@miuo.me</li>
        <li>X: <a href="https://x.com/miuo55">@miuo55</a></li>
      </ul>
    </section>
  </main>
</Layout>
