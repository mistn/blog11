---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Footer from "@/components/Footer.astro";
import SiteTopbar from "@/components/SiteTopbar.astro";
import Datetime from "@/components/Datetime.astro";
import PageSidebar from "@/components/PageSidebar.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import { SITE } from "@/config";
import { localizePath } from "@/i18n";

const locale = "en";
const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const leadPost = recentPosts[0];
const listPosts = recentPosts.slice(1, SITE.postPerIndex + 2);
---

<Layout {locale}>
  <SiteTopbar />
  <main
    id="main-content"
    data-layout="index"
    data-post-memory-scope="list"
    class="app-layout pb-10 lg:max-w-7xl lg:pb-14"
  >
    <section class="overflow-hidden">
      <div class="px-1 py-4 sm:px-2 sm:py-5">
        <div class="grid gap-10 lg:grid-cols-[minmax(0,1.78fr)_260px]">
          <div class="min-w-0">
            {
              leadPost && (
                <article class="border-b border-border/70 pb-10">
                  <a
                    href={localizePath(
                      getPath(leadPost.id, leadPost.filePath),
                      locale
                    )}
                    data-post-link
                    class="card-link-press inline-block [font-family:var(--font-ui-serif)] text-[1.9rem] leading-[1.16] font-semibold tracking-tight transition hover:text-accent sm:text-[2.2rem]"
                  >
                    {leadPost.data.title}
                  </a>
                  <Datetime
                    {...leadPost.data}
                    {locale}
                    class="mt-4 text-foreground/55 [&_svg]:scale-75 [&_svg]:opacity-70"
                  />
                  <p class="mt-6 max-w-3xl text-[1.16rem] leading-[1.95] text-foreground/82 sm:text-[1.2rem]">
                    {leadPost.data.description}
                  </p>
                </article>
              )
            }

            <div class="divide-y divide-border/55">
              {
                listPosts.map(post => (
                  <article class="py-10">
                    <a
                      href={localizePath(
                        getPath(post.id, post.filePath),
                        locale
                      )}
                      data-post-link
                      class="card-link-press inline-block [font-family:var(--font-ui-serif)] text-[1.8rem] leading-[1.22] font-semibold tracking-tight transition hover:text-accent sm:text-[2rem]"
                    >
                      {post.data.title}
                    </a>
                    <Datetime
                      {...post.data}
                      {locale}
                      class="mt-3.5 text-foreground/52 [&_svg]:scale-75 [&_svg]:opacity-70"
                    />
                    <p class="mt-4 max-w-3xl text-[1.06rem] leading-[1.9] text-foreground/74">
                      {post.data.description}
                    </p>
                  </article>
                ))
              }
            </div>
          </div>

          <PageSidebar posts={sortedPosts} {locale} />
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", window.location.pathname);
    }
  });
</script>
