---
import SiteTopbar from "@/components/SiteTopbar.astro";
import ArtalkComments from "@/components/ArtalkComments.astro";
import PageHeader from "@/components/PageHeader.astro";
import CodeSnippet from "@/components/CodeSnippet.astro";
import Layout from "@/layouts/Layout.astro";
import { defaultFriendAvatar, friendLinks, siteProfile } from "@/data/friends";
import { SITE } from "@/config";
import { ui } from "@/i18n";

const locale = "zh";
const copy = ui[locale];
const applicationFields = [
  { label: "name", value: "miuo's blog" },
  { label: "url", value: siteProfile.href },
  { label: "avatar", value: siteProfile.avatar },
  { label: "desc", value: SITE.desc },
];
const applicationText = applicationFields
  .map(field => `${field.label}: ${field.value}`)
  .join("\n");
---

<Layout
  title={`${copy.pages.friendsTitle} | ${SITE.title}`}
  description={copy.pages.friendsDesc}
  structuredDataType="CollectionPage"
  structuredData={{
    mainEntity: {
      "@type": "ItemList",
      name: copy.pages.friendsTitle,
      numberOfItems: friendLinks.length,
    },
  }}
  {locale}
>
  <SiteTopbar />

  <main id="main-content" class="mx-auto w-full max-w-5xl px-4 pt-6 pb-10 md:pt-10 md:pb-14 overflow-x-hidden">
    <PageHeader title={copy.pages.friendsTitle} />
    <section class="py-4" data-pagefind-body>
      <div class="max-w-5xl">
        <section>
          {
            friendLinks.length > 0 ? (
              <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
                {friendLinks.map(friend => (
                  <a
                    href={friend.href}
                    target="_blank"
                    rel="noreferrer"
                    class="group flex flex-col items-center rounded-2xl bg-muted/40 p-5 text-center transition-shadow transition-transform duration-300 hover:-translate-y-0.5 hover:shadow-[0_8px_30px_rgb(0,0,0,0.04)]"
                  >
                    <img
                      src={friend.avatar ?? defaultFriendAvatar}
                      alt={`${friend.name} avatar`}
                      class="mb-3 h-14 w-14 rounded-full object-cover ring-1 ring-border/40"
                      loading="lazy"
                    />
                    <h2 class="line-clamp-1 text-sm font-semibold leading-snug text-foreground">{friend.blog ?? friend.name}</h2>
                    {
                      friend.blog && friend.blog !== friend.name && (
                        <p class="mt-0.5 text-[0.7rem] leading-tight text-foreground/45">{friend.name}</p>
                      )
                    }
                    <p class="mt-1.5 line-clamp-2 text-xs leading-snug text-foreground/55">{friend.description}</p>
                  </a>
                ))}
              </div>
            ) : (
              <div class="border-y border-border/65 py-8">
                <p class="text-[1.05rem] leading-8 text-foreground/68">
                  杩欓噷鏆傛椂杩樻病鏈夊弸閾俱€備氦鎹㈠畬鎴愬悗浼氬垪鍦ㄨ繖閲屻€?
                </p>
              </div>
            )
          }
        </section>

        <section class="apply-section">
          <div>
            <p class="section-eyebrow">Apply</p>
            <h2>友链申请格式</h2>
            <p>
              申请交换友链可以在页面底部评论区按这个格式留言。已添加友链后，也可以在评论区补充需要修改的信息。
            </p>
            </p>
          </div>

          <div class="friend-application mt-6">
            <p class="friend-application-title">申请模板</p>
            <CodeSnippet code={applicationText} language="yaml" />
          </div>
        </section>
      </div>

      <div class="max-w-5xl">
        <ArtalkComments pageKey="/friends" pageTitle={copy.pages.friendsTitle} />
      </div>
    </section>
  </main>

</Layout>

<style>
  .apply-section {
    margin-top: 2.6rem;
    border-top: 1px solid color-mix(in srgb, var(--border) 68%, transparent);
    padding-top: 2.6rem;
  }

  .section-eyebrow {
    color: color-mix(in srgb, var(--foreground) 52%, transparent);
    font-size: 0.76rem;
    font-weight: 500;
    letter-spacing: 0.32em;
    text-transform: uppercase;
  }

  .apply-section h2 {
    margin-top: 0.75rem;
    font-size: 1.85rem;
    font-weight: 600;
    line-height: 1.18;
  }

  .apply-section p:not(.section-eyebrow) {
    max-width: 42rem;
    margin-top: 1rem;
    color: color-mix(in srgb, var(--foreground) 82%, transparent);
    font-size: 1rem;
    line-height: 2;
  }

  .friend-application {
    position: relative;
  }

  .friend-application-title {
    margin: 0 0 0.5rem;
    color: color-mix(in srgb, var(--foreground) 88%, transparent);
    font-size: 0.9rem;
    font-weight: 600;
  }


  @media (max-width: 639px) {
    .apply-section {
      margin-top: 2rem;
      padding-top: 2rem;
    }

    .apply-section h2 {
      font-size: 1.55rem;
    }

    .friend-application-title {
      font-size: 0.82rem;
    }
  }
</style>
