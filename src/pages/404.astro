---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import LinkButton from "@/components/LinkButton.astro";
import { SITE } from "@/config";
import { getLocaleFromPath, localizePath, ui } from "@/i18n";

const locale = getLocaleFromPath(Astro.url.pathname);
const copy = ui[locale];
---

<Layout title={`404 ${copy.pages.notFoundTitle} | ${SITE.title}`}>
  <Header />

  <main
    id="main-content"
    class="app-layout flex flex-1 items-center justify-center"
  >
    <div class="mb-14 flex flex-col items-center justify-center">
      <h1 class="text-9xl font-bold text-accent">404</h1>
      <span aria-hidden="true">¯\_(ツ)_/¯</span>
      <p class="mt-4 text-2xl sm:text-3xl">{copy.pages.notFoundTitle}</p>
      <LinkButton
        href={localizePath("/", locale)}
        class="my-6 text-lg underline decoration-dashed underline-offset-8"
      >
        {copy.pages.notFoundCta}
      </LinkButton>
    </div>
  </main>

</Layout>
