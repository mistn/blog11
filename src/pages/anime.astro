---
import BackToTopButton from "@/components/BackToTopButton.astro";
import Footer from "@/components/Footer.astro";
import SiteTopbar from "@/components/SiteTopbar.astro";
import Layout from "@/layouts/Layout.astro";
import animeData from "@/data/anime.generated.json";
import type { AnimeDataPayload, AnimeItem } from "@/types/anime";

const data = animeData as AnimeDataPayload;

function getEntryKey(entry: AnimeItem) {
  return (
    entry.url || [entry.title.trim(), entry.cover, entry.year ?? ""].join("::")
  );
}

function groupItems(items: AnimeItem[]) {
  const seen = new Set<string>();
  const groups = new Map<string, AnimeItem[]>();

  for (const item of items ?? []) {
    const key = getEntryKey(item);
    if (!item?.title || !item?.cover || !item?.url || seen.has(key)) continue;
    seen.add(key);

    const yearLabel = item.year ? String(item.year) : "未标年份";
    const list = groups.get(yearLabel);

    if (list) list.push(item);
    else groups.set(yearLabel, [item]);
  }

  return Array.from(groups.entries())
    .sort((a, b) => Number(b[0] || 0) - Number(a[0] || 0))
    .map(([yearLabel, entries]) => ({
      yearLabel,
      entries,
    }));
}

const groups = groupItems(data.items ?? []);
const total = groups.reduce((sum, group) => sum + group.entries.length, 0);
const pageTitle = "追番列表 | miuo";
const pageDescription = "按年份整理 AniList normal 列表中已看完的动画。";
const sourceHref = data.username
  ? `https://anilist.co/user/${data.username}`
  : "https://anilist.co";

const updatedLabel = data.updatedAt
  ? new Intl.DateTimeFormat("zh-CN", {
      year: "numeric",
      month: "2-digit",
      day: "2-digit",
      hour: "2-digit",
      minute: "2-digit",
      hour12: false,
      timeZone: "Asia/Shanghai",
    }).format(new Date(data.updatedAt))
  : null;
---

<Layout
  title={pageTitle}
  description={pageDescription}
  structuredDataType="CollectionPage"
  structuredData={{
    mainEntity: {
      "@type": "ItemList",
      name: "追番列表",
      numberOfItems: total,
    },
    about: "AniList completed anime collection filtered by custom list normal.",
  }}
>
  <SiteTopbar />

  <main class="app-layout pb-14 lg:max-w-7xl lg:pb-18" data-pagefind-body>
    <section class="px-1 pt-5 sm:px-2 sm:pt-7">
      <div transition:name="page-body">
        <header class="max-w-4xl">
          <p
            class="text-[0.76rem] font-medium tracking-[0.2em] text-foreground/36 uppercase"
          >
            Anime Archive
          </p>
          <h1
            class="mt-2 [font-family:var(--font-ui-serif)] text-[2.3rem] leading-none font-semibold tracking-tight text-foreground sm:text-[2.8rem]"
          >
            追番列表
          </h1>
          <div
            class="mt-4 flex flex-wrap items-center gap-3 text-sm text-foreground/56"
          >
            <span>{total} 部</span>
            <span>
              数据来自
              <a
                href={sourceHref}
                target="_blank"
                rel="noreferrer"
                class="ml-1 text-accent underline decoration-accent/35 underline-offset-4"
              >
                AniList{data.username ? ` / ${data.username}` : ""}
              </a>
            </span>
            <span>normal / completed</span>
            {updatedLabel && <span>更新于 {updatedLabel}</span>}
          </div>
        </header>

        {
          groups.length > 0 ? (
            <div class="mt-10">
              {groups.map(group => (
                <section class="not-last:mb-14">
                  <div class="flex items-end justify-between gap-4 border-b border-border/65 pb-3">
                    <h2 class="[font-family:var(--font-ui-serif)] text-[2.2rem] leading-none font-semibold tracking-tight sm:text-[2.7rem]">
                      {group.yearLabel}
                    </h2>
                    <p class="pb-1 text-sm text-foreground/46">
                      {group.entries.length} 部
                    </p>
                  </div>

                  <div class="mt-6 grid grid-cols-2 gap-x-5 gap-y-8 sm:grid-cols-3 lg:grid-cols-5 xl:grid-cols-6">
                    {group.entries.map(entry => (
                      <a
                        href={entry.url}
                        target="_blank"
                        rel="noreferrer"
                        class="group max-w-[176px] min-w-0 text-foreground"
                      >
                        <div class="overflow-hidden rounded-[1.25rem] bg-muted">
                          <img
                            src={entry.cover}
                            alt={`${entry.title} cover`}
                            class="aspect-[2/3] w-full object-cover transition duration-300 group-hover:scale-[1.02] group-hover:opacity-92"
                            loading="lazy"
                          />
                        </div>

                        <div class="mt-3">
                          <h3 class="line-clamp-2 text-[0.98rem] leading-7 font-medium transition group-hover:text-accent">
                            {entry.title}
                          </h3>
                        </div>
                      </a>
                    ))}
                  </div>
                </section>
              ))}
            </div>
          ) : (
            <div class="mt-10 border-t border-border/65 pt-8">
              <p class="text-[1.02rem] leading-8 text-foreground/66">
                这里还没有同步到追番数据。
              </p>
              <p class="mt-2 text-sm leading-7 text-foreground/52">
                运行 <code>pnpm run anime:sync</code>，脚本会抓取
                <code>miuol</code> 的 AniList 数据，并保留
                <code>normal</code> 列表里状态为 <code>COMPLETED</code> 的动画。
              </p>
            </div>
          )
        }
      </div>
    </section>
  </main>

  <BackToTopButton />
  <Footer />
</Layout>
