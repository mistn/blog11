---
import Footer from "@/components/Footer.astro";
import SiteTopbar from "@/components/SiteTopbar.astro";
import Layout from "@/layouts/Layout.astro";
import animeData from "@/data/anime.generated.json";
import type {
  AnimeCollectionData,
  AnimeEntry,
  AnimeYearGroup,
} from "@/types/anime";

const rawData = animeData as AnimeCollectionData;

const statusMap: Record<string, string> = {
  COMPLETED: "已看完",
};

const formatMap: Record<string, string> = {
  TV: "TV",
  TV_SHORT: "短篇",
  MOVIE: "剧场版",
  SPECIAL: "特别篇",
  OVA: "OVA",
  ONA: "ONA",
  MUSIC: "MV",
};

const seasonMap: Record<string, string> = {
  WINTER: "冬",
  SPRING: "春",
  SUMMER: "夏",
  FALL: "秋",
};

function dedupeGroups(data: AnimeCollectionData) {
  const seen = new Map<number | string, AnimeEntry>();
  const groups = new Map<string, AnimeYearGroup>();

  for (const group of data.groups ?? []) {
    for (const entry of group.entries ?? []) {
      const key = entry.id || entry.siteUrl;
      if (seen.has(key)) continue;
      seen.set(key, entry);

      const groupKey = group.yearLabel;
      if (!groups.has(groupKey)) {
        groups.set(groupKey, {
          year: group.year,
          yearLabel: group.yearLabel,
          entries: [],
        });
      }

      groups.get(groupKey)?.entries.push(entry);
    }
  }

  const normalizedGroups = Array.from(groups.values());
  return {
    ...data,
    total: seen.size,
    groups: normalizedGroups,
  };
}

const data = dedupeGroups(rawData);

const pageTitle = "追番列表 | miuo";
const pageDescription = "按年份整理 AniList normal 列表中已看完的动画。";

const sourceHref =
  data.source.userUrl ??
  (data.source.userName
    ? `https://anilist.co/user/${data.source.userName}`
    : data.source.url);

const generatedLabel = data.generatedAt
  ? new Intl.DateTimeFormat("zh-CN", {
      year: "numeric",
      month: "2-digit",
      day: "2-digit",
      hour: "2-digit",
      minute: "2-digit",
      hour12: false,
      timeZone: "Asia/Shanghai",
    }).format(new Date(data.generatedAt))
  : null;
---

<Layout
  title={pageTitle}
  description={pageDescription}
  structuredDataType="CollectionPage"
  structuredData={{
    mainEntity: {
      "@type": "ItemList",
      name: "追番列表",
      numberOfItems: data.total,
    },
    about: "AniList completed anime collection filtered by custom list normal.",
  }}
>
  <SiteTopbar />

  <main class="app-layout pb-14 lg:max-w-7xl lg:pb-18" data-pagefind-body>
    <section class="px-1 pt-5 sm:px-2 sm:pt-7">
      <div
        transition:name="page-body"
        class="overflow-hidden rounded-[2rem] border border-border/70 bg-background/82 shadow-[0_18px_60px_rgba(36,77,136,0.08)] backdrop-blur-sm"
      >
        <div
          class="relative border-b border-border/70 px-5 py-6 sm:px-8 sm:py-7"
        >
          <div
            class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent/35 to-transparent"
          >
          </div>

          <div class="max-w-4xl">
            <p
              class="text-[0.78rem] font-medium tracking-[0.22em] text-foreground/40 uppercase"
            >
              Anime Archive
            </p>
            <h1
              class="mt-2 [font-family:var(--font-ui-serif)] text-[2.6rem] leading-none font-semibold tracking-tight text-foreground sm:text-[3rem]"
            >
              追番列表
            </h1>
            <p
              class="mt-3 max-w-3xl text-[0.98rem] leading-7 text-foreground/62"
            >
              AniList `normal` 列表里已看完动画的简单整理。
            </p>

            <div
              class="mt-5 flex flex-wrap items-center gap-3 text-sm text-foreground/58"
            >
              <span
                class="rounded-full border border-border/70 bg-muted/58 px-3 py-1.5"
              >
                {data.total} 部
              </span>
              <span>
                数据来自
                <a
                  href={sourceHref}
                  target="_blank"
                  rel="noreferrer"
                  class="ml-1 text-accent underline decoration-accent/35 underline-offset-4"
                >
                  {data.source.name}
                  {data.source.userName ? ` / ${data.source.userName}` : ""}
                </a>
              </span>
              <span class="text-foreground/45">
                {data.source.customListName} / completed
              </span>
              {
                generatedLabel && (
                  <span class="text-foreground/45">
                    更新于 {generatedLabel}
                  </span>
                )
              }
            </div>
          </div>
        </div>

        {
          data.groups.length > 0 ? (
            <div class="px-5 py-6 sm:px-8 sm:py-8">
              {data.groups.map(group => (
                <section class="not-last:mb-12">
                  <div class="flex items-end justify-between gap-4 border-b border-border/65 pb-3">
                    <h2 class="[font-family:var(--font-ui-serif)] text-[2.2rem] leading-none font-semibold tracking-tight sm:text-[2.8rem]">
                      {group.yearLabel}
                    </h2>
                    <p class="pb-1 text-sm text-foreground/48">
                      {group.entries.length} 部
                    </p>
                  </div>

                  <div class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
                    {group.entries.map(entry => (
                      <a
                        href={entry.siteUrl}
                        target="_blank"
                        rel="noreferrer"
                        class="group overflow-hidden rounded-[1.5rem] border border-border/70 bg-background/88 transition duration-200 hover:-translate-y-1 hover:border-accent/28 hover:shadow-[0_20px_50px_rgba(36,77,136,0.12)]"
                      >
                        <div class="relative aspect-[2/3] overflow-hidden bg-muted">
                          {entry.coverImage ? (
                            <img
                              src={entry.coverImage}
                              alt={`${entry.title} cover`}
                              class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]"
                              loading="lazy"
                            />
                          ) : (
                            <div class="flex h-full items-center justify-center text-sm text-foreground/42">
                              No Cover
                            </div>
                          )}
                          <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-black/55 to-transparent" />
                          <div class="absolute right-3 bottom-3">
                            <span class="rounded-full border border-white/18 bg-black/38 px-2.5 py-1 text-[0.72rem] font-medium tracking-[0.16em] text-white/92 uppercase backdrop-blur-sm">
                              {statusMap[entry.status ?? ""] ?? "记录"}
                            </span>
                          </div>
                        </div>

                        <div class="px-4 py-4">
                          <h3 class="line-clamp-2 text-[1.02rem] leading-7 font-medium text-foreground transition group-hover:text-accent">
                            {entry.title}
                          </h3>

                          {entry.titleNative && (
                            <p class="mt-1 line-clamp-1 text-sm text-foreground/48">
                              {entry.titleNative}
                            </p>
                          )}

                          <div class="mt-4 flex flex-wrap gap-2 text-[0.76rem] text-foreground/56">
                            {entry.format && (
                              <span class="rounded-full border border-border/70 px-2.5 py-1">
                                {formatMap[entry.format] ?? entry.format}
                              </span>
                            )}
                            {entry.season && (
                              <span class="rounded-full border border-border/70 px-2.5 py-1">
                                {seasonMap[entry.season] ?? entry.season}
                              </span>
                            )}
                            {entry.score !== null && (
                              <span class="rounded-full border border-border/70 px-2.5 py-1">
                                {entry.score.toFixed(1)} 分
                              </span>
                            )}
                          </div>

                          <div class="mt-4 flex items-center justify-between gap-4 text-sm text-foreground/62">
                            <p>
                              进度
                              <span class="ml-1 text-foreground">
                                {entry.progress}
                                {entry.episodes ? ` / ${entry.episodes}` : "+"}
                              </span>
                            </p>
                            {entry.studios[0] && (
                              <p class="truncate text-right text-foreground/48">
                                {entry.studios[0]}
                              </p>
                            )}
                          </div>
                        </div>
                      </a>
                    ))}
                  </div>
                </section>
              ))}
            </div>
          ) : (
            <div class="px-5 py-10 sm:px-8">
              <div class="rounded-[1.6rem] border border-dashed border-border/70 bg-muted/35 px-5 py-7 sm:px-6">
                <p class="text-[1.05rem] leading-8 text-foreground/68">
                  这里还没有同步到追番数据。
                </p>
                <p class="mt-3 text-sm leading-7 text-foreground/52">
                  运行 <code>pnpm run anime:sync</code>，脚本会抓取
                  <code>uoooouuur</code> 的 AniList 数据，并保留
                  <code>normal</code> 列表里状态为 <code>COMPLETED</code>{" "}
                  的动画。
                </p>
              </div>
            </div>
          )
        }
      </div>
    </section>
  </main>

  <Footer />
</Layout>
