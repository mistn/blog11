---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import SiteTopbar from "@/components/SiteTopbar.astro";
import Datetime from "@/components/Datetime.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import { SITE } from "@/config";
import { getLocaleFromPath, localizePath } from "@/i18n";

const posts = await getCollection("blog");
const locale = getLocaleFromPath(Astro.url.pathname);
const sortedPosts = getSortedPosts(posts);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const listPosts = recentPosts.slice(0, SITE.postPerPage);
const totalPages = Math.ceil(recentPosts.length / SITE.postPerPage);
const pageNumbers = Array.from({ length: totalPages }, (_, index) => index + 1);
---

<Layout>
  <SiteTopbar />
  <main
    id="main-content"
    data-layout="index"
    data-post-memory-scope="list"
    class="mx-auto w-full max-w-4xl px-4 pt-8 pb-10 md:pt-12 md:pb-14"
  >
    <section class="overflow-hidden">
      <div class="px-1 py-2 sm:px-2 md:py-5">
        <div>
          <div class="min-w-0">
            <div data-post-list>
              {
                listPosts.map(post => (
                  <article class="py-6 md:py-10" data-post-item>
                    <a
                      href={localizePath(getPath(post.id, post.filePath), locale)}
                      data-post-link
                      class="card-link-press inline-block text-[1.45rem] leading-tight font-medium tracking-tight transition hover:text-accent"
                    >
                      {post.data.title}
                    </a>
                    <Datetime
                      {...post.data}
                      {locale}
                      class="mt-2.5 md:mt-3.5 text-foreground/52 [&_svg]:scale-75 [&_svg]:opacity-70"
                    />
                    <p class="mt-3 md:mt-4 max-w-3xl text-sm leading-relaxed text-gray-600 dark:text-gray-400 md:text-base line-clamp-2">
                      {post.data.description}
                    </p>
                  </article>
                ))
              }
            </div>
            {totalPages > 1 && (
              <nav class="mt-6 md:mt-12 flex justify-center items-center gap-6" aria-label="Pagination Navigation">
                {pageNumbers.map(pageNumber => (
                  <a
                    href={
                      pageNumber === 1
                        ? localizePath("/", locale)
                        : localizePath(`/posts/${pageNumber}`, locale)
                    }
                    class={
                      pageNumber === 1
                        ? "text-gray-800 dark:text-gray-200 font-semibold text-base"
                        : "text-gray-400 dark:text-gray-500 hover:text-gray-900 dark:hover:text-gray-100 transition-colors text-base"
                    }
                    aria-current={pageNumber === 1 ? "page" : undefined}
                  >
                    {pageNumber}
                  </a>
                ))}
              </nav>
            )}
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", window.location.pathname);
    }
  });
</script>
