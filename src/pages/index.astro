---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Footer from "@/components/Footer.astro";
import SiteTopbar from "@/components/SiteTopbar.astro";
import HomeTabs from "@/components/HomeTabs.astro";
import Datetime from "@/components/Datetime.astro";
import PageSidebar from "@/components/PageSidebar.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import { SITE } from "@/config";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const leadPost = recentPosts[0];
const listPosts = recentPosts.slice(1, SITE.postPerIndex + 2);
---

<Layout>
  <SiteTopbar />
  <main
    id="main-content"
    data-layout="index"
    class="app-layout pb-6 lg:max-w-7xl lg:pb-8"
  >
    <section class="overflow-hidden bg-transparent dark:bg-[#262b3a]">
      <div class="p-5 sm:p-6 lg:p-8">
        <div class="grid gap-5 lg:grid-cols-[minmax(0,1.65fr)_300px]">
          <div transition:name="page-body" class="space-y-5 min-w-0">
            <HomeTabs />
            {
              leadPost && (
                <article class="relative overflow-visible rounded-[1rem] border border-[#e7dece] bg-[#fcfaf5] px-6 py-6 dark:border-[#42516b] dark:bg-[#2a3347] sm:px-7">
                  <div class="absolute -top-4 -left-4 z-10 h-12 w-12 overflow-hidden rounded-full border border-[#ddd3c0] bg-[#fcfaf5] dark:border-[#51627d] dark:bg-[#2a3347]">
                    <img src="/avatar.avif" alt="avatar" class="h-full w-full object-cover" loading="eager" />
                  </div>
                  <div class="pt-1">
                    <a
                      href={getPath(leadPost.id, leadPost.filePath)}
                      class="card-link-press block text-[2rem] leading-tight font-semibold tracking-tight transition hover:text-accent sm:text-[2.45rem]"
                    >
                      {leadPost.data.title}
                    </a>
                    <Datetime {...leadPost.data} class="mt-4 text-foreground/60 [&_svg]:scale-75 [&_svg]:opacity-70" />
                    <p class="mt-5 max-w-3xl text-[1.05rem] leading-9 text-foreground/82">
                      {leadPost.data.description}
                    </p>
                  </div>
                </article>
              )
            }

            {
              listPosts.map(post => (
                <article class="relative overflow-visible rounded-[0.95rem] border border-[#e7dece] bg-[#fcfaf5] px-6 py-6 dark:border-[#42516b] dark:bg-[#2a3347] sm:px-7">
                  <div class="absolute -top-3.5 -left-3.5 z-10 h-11 w-11 overflow-hidden rounded-full border border-[#ddd3c0] bg-[#fcfaf5] dark:border-[#51627d] dark:bg-[#2a3347]">
                    <img src="/avatar.avif" alt="avatar" class="h-full w-full object-cover" loading="eager" />
                  </div>
                  <div class="pt-1">
                    <a
                      href={getPath(post.id, post.filePath)}
                      class="card-link-press block text-[1.75rem] leading-tight font-semibold tracking-tight transition hover:text-accent sm:text-[1.95rem]"
                    >
                      {post.data.title}
                    </a>
                    <Datetime {...post.data} class="mt-3 text-foreground/58 [&_svg]:scale-75 [&_svg]:opacity-70" />
                    <p class="mt-4 max-w-3xl text-[1rem] leading-8 text-foreground/76">
                      {post.data.description}
                    </p>
                  </div>
                </article>
              ))
            }
          </div>

          <PageSidebar posts={sortedPosts} />
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
