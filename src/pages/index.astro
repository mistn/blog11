---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import SiteTopbar from "@/components/SiteTopbar.astro";
import Datetime from "@/components/Datetime.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import { SITE } from "@/config";
import { getLocaleFromPath, localizePath } from "@/i18n";

const posts = await getCollection("blog");
const locale = getLocaleFromPath(Astro.url.pathname);
const sortedPosts = getSortedPosts(posts);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const leadPost = recentPosts[0];
const listPosts = recentPosts.slice(1, SITE.postPerPage);
const totalPages = Math.ceil(recentPosts.length / SITE.postPerPage);
const pageNumbers = Array.from({ length: totalPages }, (_, index) => index + 1);
---

<Layout>
  <SiteTopbar />
  <main
    id="main-content"
    data-layout="index"
    data-post-memory-scope="list"
    class="app-layout pb-4 md:pb-10"
  >
    <section class="overflow-hidden">
      <div class="px-1 py-4 sm:px-2 sm:py-5">
        <div>
          <div class="min-w-0">
            {
              leadPost && (
                <article class="pb-10">
                  <a
                    href={localizePath(
                      getPath(leadPost.id, leadPost.filePath),
                      locale
                    )}
                    data-post-link
                    class="card-link-press inline-block text-[1.9rem] leading-[1.16] font-medium tracking-tight transition hover:text-accent sm:text-[2.2rem]"
                  >
                    {leadPost.data.title}
                  </a>
                  <Datetime
                    {...leadPost.data}
                    locale={locale}
                    class="mt-4 text-foreground/55 [&_svg]:scale-75 [&_svg]:opacity-70"
                  />
                  <p class="mt-6 max-w-3xl text-[1.16rem] leading-[1.95] text-foreground/92 sm:text-[1.2rem]">
                    {leadPost.data.description}
                  </p>
                </article>
              )
            }

            <div data-post-list>
              {
                listPosts.map(post => (
                  <article class="py-10" data-post-item>
                    <a
                      href={localizePath(
                        getPath(post.id, post.filePath),
                        locale
                      )}
                      data-post-link
                      class="card-link-press inline-block text-[1.8rem] leading-[1.22] font-medium tracking-tight transition hover:text-accent sm:text-[2rem]"
                    >
                      {post.data.title}
                    </a>
                    <Datetime
                      {...post.data}
                      locale={locale}
                      class="mt-3.5 text-foreground/52 [&_svg]:scale-75 [&_svg]:opacity-70"
                    />
                    <p class="mt-4 max-w-3xl text-[1.06rem] leading-[1.9] text-foreground/88">
                      {post.data.description}
                    </p>
                  </article>
                ))
              }
            </div>
            {totalPages > 1 && (
              <nav class="mt-6 md:mt-12 flex justify-center items-center gap-4" aria-label="Pagination Navigation">
                {pageNumbers.map(pageNumber => (
                  <a
                    href={
                      pageNumber === 1
                        ? localizePath("/", locale)
                        : localizePath(`/posts/${pageNumber}`, locale)
                    }
                    class={
                      pageNumber === 1
                        ? "px-4 py-1.5 bg-gray-100 text-gray-900 font-bold rounded-full"
                        : "text-gray-400 hover:text-gray-900 transition-colors"
                    }
                    aria-current={pageNumber === 1 ? "page" : undefined}
                  >
                    {pageNumber}
                  </a>
                ))}
              </nav>
            )}
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", window.location.pathname);
    }
  });
</script>
