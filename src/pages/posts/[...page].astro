---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import SiteTopbar from "@/components/SiteTopbar.astro";
import Datetime from "@/components/Datetime.astro";
import PageSidebar from "@/components/PageSidebar.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import { SITE } from "@/config";
import { getLocaleFromPath, localizePath, ui } from "@/i18n";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return paginate(getSortedPosts(posts), { pageSize: SITE.postPerPage });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const locale = getLocaleFromPath(Astro.url.pathname);
const copy = ui[locale];
const posts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = getSortedPosts(posts);
const listPosts = page.data;
const pageNumbers = Array.from(
  { length: page.lastPage },
  (_, index) => index + 1
);

function getPageHref(pageNumber: number) {
  if (pageNumber === 1) return localizePath("/", locale);
  return localizePath(`/posts/${pageNumber}`, locale);
}
---

<Layout title={`${copy.pages.postsTitle} | ${SITE.title}`}>
  <SiteTopbar />
  <main
    id="main-content"
    data-layout="index"
    data-post-memory-scope="list"
    class="app-layout pb-10 lg:max-w-7xl lg:pb-14"
  >
    <section class="overflow-hidden">
      <div class="px-1 py-4 sm:px-2 sm:py-5">
        <div class="grid gap-10 lg:grid-cols-[minmax(0,1.78fr)_260px]">
          <div class="min-w-0">
            <div class="divide-y divide-border/55" data-post-list>
              {
                listPosts.map(post => (
                  <article class="py-10" data-post-item>
                    <a
                      href={localizePath(getPath(post.id, post.filePath), locale)}
                      data-post-link
                      class="card-link-press inline-block text-[1.8rem] leading-[1.22] font-medium tracking-tight transition hover:text-accent sm:text-[2rem]"
                    >
                      {post.data.title}
                    </a>
                    <Datetime
                      {...post.data}
                      {locale}
                      class="mt-3.5 text-foreground/52 [&_svg]:scale-75 [&_svg]:opacity-70"
                    />
                    <p class="mt-4 max-w-3xl text-[1.06rem] leading-[1.9] text-foreground/88">
                      {post.data.description}
                    </p>
                  </article>
                ))
              }
            </div>

            {page.lastPage > 1 && (
              <nav
                class="page-number-nav"
                aria-label="Pagination Navigation"
              >
                <div class="page-number-group">
                  {pageNumbers.map(pageNumber => (
                    <a
                      href={getPageHref(pageNumber)}
                      class={
                        pageNumber === page.currentPage
                          ? "page-number-current"
                          : "page-number-item"
                      }
                      aria-current={
                        pageNumber === page.currentPage ? "page" : undefined
                      }
                    >
                      {pageNumber}
                    </a>
                  ))}
                </div>
              </nav>
            )}
          </div>

          <PageSidebar posts={sortedPosts} {locale} />
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    sessionStorage.setItem("backUrl", window.location.pathname);
  });
</script>
