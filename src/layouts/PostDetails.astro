---
import { render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Footer from "@/components/Footer.astro";
import SiteTopbar from "@/components/SiteTopbar.astro";
import PageSidebar from "@/components/PageSidebar.astro";
import Tag from "@/components/Tag.astro";
import Datetime from "@/components/Datetime.astro";
import EditPost from "@/components/EditPost.astro";
import ArtalkComments from "@/components/ArtalkComments.astro";
import ArticleImageLightbox from "@/components/ArticleImageLightbox.astro";
import BackButton from "@/components/BackButton.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import { slugifyStr } from "@/utils/slugify";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";
import { SITE } from "@/config";
import { getLocaleFromPath, localizePath, ui, type Locale } from "@/i18n";

type Props = {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
  locale?: Locale;
};

const {
  post,
  posts,
  locale = getLocaleFromPath(Astro.url.pathname),
} = Astro.props;
const copy = ui[locale];

const {
  title,
  author,
  description,
  ogImage: initOgImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  timezone,
  tags,
  hideEditPost,
} = post.data;

const { Content, headings } = await render(post);

let ogImageUrl: string | undefined;

if (typeof initOgImage === "string") {
  ogImageUrl = initOgImage;
} else if (initOgImage?.src) {
  ogImageUrl = initOgImage.src;
}

if (!ogImageUrl && SITE.dynamicOgImage) {
  ogImageUrl = `${getPath(post.id, post.filePath)}/index.png`;
}

const ogImage = ogImageUrl
  ? new URL(ogImageUrl, Astro.url.origin).href
  : undefined;

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage,
  scrollSmooth: true,
  locale,
};

const sortedPosts = getSortedPosts(posts);

const allPosts = sortedPosts.map(({ data: { title }, id, filePath }) => ({
  id,
  title,
  filePath,
}));

const currentPostIndex = allPosts.findIndex(a => a.id === post.id);

const prevPost = currentPostIndex !== 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex !== allPosts.length - 1
    ? allPosts[currentPostIndex + 1]
    : null;
---

<Layout {...layoutProps}>
  <SiteTopbar />
  <main
    id="main-content"
    data-post-memory-scope="post"
    class="app-layout pb-10 lg:max-w-7xl lg:pb-14"
  >
    <section>
      <div class="px-1 py-4 sm:px-2 sm:py-5">
        <div class="grid gap-10 lg:grid-cols-[minmax(0,1.78fr)_260px]">
          <div class="min-w-0">
            <BackButton inline {locale} />

            <article class="pt-2" data-pagefind-body>
              <h1
                data-article-enter
                style="--article-enter-delay: 0ms;"
                data-article-enter-type="title"
                class="max-w-4xl [font-family:var(--font-ui-serif)] text-[2.25rem] leading-[1.14] font-semibold tracking-tight sm:text-[2.7rem]"
              >
                {title}
              </h1>

              <div
                data-article-enter
                style="--article-enter-delay: 26ms;"
                class="mt-5 flex flex-wrap items-center gap-2 text-foreground/60"
              >
                <Datetime
                  {pubDatetime}
                  {modDatetime}
                  {timezone}
                  size="lg"
                  {locale}
                />
                <span
                  aria-hidden="true"
                  class:list={[
                    "max-sm:hidden",
                    { hidden: !SITE.editPost.enabled || hideEditPost },
                  ]}>|</span
                >
                <EditPost
                  {hideEditPost}
                  {post}
                  {locale}
                  class="max-sm:hidden"
                />
              </div>

              <div
                id="article"
                data-article-enter
                style="--article-enter-delay: 54ms;"
                data-article-enter-type="content"
                class="app-prose mt-10 w-full max-w-4xl"
              >
                <Content />
              </div>

              <hr class="my-10 border-border/60" />

              <EditPost class="sm:hidden" {hideEditPost} {post} {locale} />

              <ul
                data-article-enter
                style="--article-enter-delay: 88ms;"
                class="mt-4 mb-10 flex flex-wrap gap-4 sm:my-8"
              >
                {
                  tags.map(tag => (
                    <Tag
                      tag={slugifyStr(tag)}
                      tagName={tag}
                      size="sm"
                      {locale}
                    />
                  ))
                }
              </ul>

              <ArtalkComments
                pageKey={getPath(post.id, post.filePath)}
                pageTitle={title}
              />

              <hr class="my-8 border-border/60" />

              <div
                data-pagefind-ignore
                data-article-enter
                style="--article-enter-delay: 112ms;"
                class="grid grid-cols-1 gap-6 sm:grid-cols-2"
              >
                {
                  prevPost && (
                    <a
                      href={localizePath(
                        getPath(prevPost.id, prevPost.filePath),
                        locale
                      )}
                      class="flex w-full gap-1 text-foreground/72 transition hover:text-accent"
                    >
                      <IconChevronLeft class="inline-block flex-none rtl:rotate-180" />
                      <div>
                        <span>{copy.actions.previousPost}</span>
                        <div class="text-sm text-foreground/56">
                          {prevPost.title}
                        </div>
                      </div>
                    </a>
                  )
                }
                {
                  nextPost && (
                    <a
                      href={localizePath(
                        getPath(nextPost.id, nextPost.filePath),
                        locale
                      )}
                      class="flex w-full justify-end gap-1 text-end text-foreground/72 transition hover:text-accent sm:col-start-2"
                    >
                      <div>
                        <span>{copy.actions.nextPost}</span>
                        <div class="text-sm text-foreground/56">
                          {nextPost.title}
                        </div>
                      </div>
                      <IconChevronRight class="inline-block flex-none rtl:rotate-180" />
                    </a>
                  )
                }
              </div>
            </article>

            <TableOfContents {headings} {locale} />
            <BackToTopButton {locale} />
          </div>

          <PageSidebar posts={sortedPosts} {locale} />
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <ArticleImageLightbox {locale} />
</Layout>

<script
  is:inline
  data-astro-rerun
  define:vars={{
    copyCodeLabel: copy.actions.copy,
    copiedCodeLabel: copy.actions.copied,
    openImageLabel: locale === "en" ? "Open image preview" : "打开图片预览",
  }}
>
  function runArticleEnterAnimation() {
    const nodes = Array.from(document.querySelectorAll("[data-article-enter]"));

    for (const node of nodes) {
      node.classList.remove("article-enter");
      // Force a reflow so the animation reliably restarts after client-side swaps.
      void node.offsetWidth;
      node.classList.add("article-enter");
    }
  }

  function addHeadingLinks() {
    const headings = Array.from(
      document.querySelectorAll("h2, h3, h4, h5, h6")
    );
    for (const heading of headings) {
      heading.classList.add("group");
      const link = document.createElement("a");
      link.className =
        "heading-link ms-2 no-underline opacity-75 md:opacity-0 md:group-hover:opacity-100 md:focus:opacity-100";
      link.href = "#" + heading.id;

      const span = document.createElement("span");
      span.ariaHidden = "true";
      span.innerText = "#";
      link.appendChild(span);
      heading.appendChild(link);
    }
  }
  addHeadingLinks();

  function attachCopyButtons() {
    const copyButtonLabel = copyCodeLabel;
    const codeBlocks = Array.from(document.querySelectorAll("pre"));
    const languageLabels = new Map([
      ["bash", "Bash"],
      ["bat", "Batch"],
      ["cmd", "Command Prompt"],
      ["css", "CSS"],
      ["dockerfile", "Dockerfile"],
      ["gitignore", "Git Ignore"],
      ["html", "HTML"],
      ["js", "JavaScript"],
      ["javascript", "JavaScript"],
      ["json", "JSON"],
      ["md", "Markdown"],
      ["markdown", "Markdown"],
      ["powershell", "PowerShell"],
      ["ps1", "PowerShell"],
      ["shell", "Shell"],
      ["sh", "Shell"],
      ["toml", "TOML"],
      ["ts", "TypeScript"],
      ["typescript", "TypeScript"],
      ["xml", "XML"],
      ["yaml", "YAML"],
      ["yml", "YAML"],
    ]);

    for (const codeBlock of codeBlocks) {
      if (codeBlock.closest(".code-block-frame")) continue;

      const wrapper = document.createElement("div");
      wrapper.className = "code-block-frame";

      const header = createCodeHeader(codeBlock);
      const copyButton = document.createElement("button");
      copyButton.className = "copy-code";
      copyButton.type = "button";
      copyButton.ariaLabel = copyButtonLabel;
      copyButton.title = copyButtonLabel;
      copyButton.innerHTML = getCopyButtonContent(copyButtonLabel);
      header.appendChild(copyButton);

      codeBlock.setAttribute("tabindex", "0");

      codeBlock?.parentNode?.insertBefore(wrapper, codeBlock);
      wrapper.appendChild(header);
      wrapper.appendChild(codeBlock);

      copyButton.addEventListener("click", async () => {
        await copyCode(codeBlock, copyButton);
      });
    }

    function getLanguageLabel(language) {
      if (
        !language ||
        language === "text" ||
        language === "txt" ||
        language === "plain"
      ) {
        return null;
      }

      return languageLabels.get(language.toLowerCase()) ?? language.toUpperCase();
    }

    function createLanguageBadge(languageLabel, compact = false) {
      const badge = document.createElement("span");
      badge.className = compact ? "code-language-badge" : "code-meta-primary";
      badge.innerText = languageLabel;
      return badge;
    }

    function createCodeHeader(codeBlock) {
      const header = document.createElement("div");
      header.className = "code-block-header";

      const meta = document.createElement("div");
      meta.className = "code-block-meta";
      meta.innerHTML = getCodeIcon();

      const languageLabel = getLanguageLabel(codeBlock.dataset.language);
      const fileName = codeBlock.dataset.codeFile;

      if (fileName) {
        const file = document.createElement("span");
        file.className = "code-meta-primary";
        file.innerText = fileName;
        meta.appendChild(file);

        if (languageLabel) {
          meta.appendChild(createLanguageBadge(languageLabel, true));
        }
      } else if (languageLabel) {
        meta.appendChild(createLanguageBadge(languageLabel));
      } else {
        meta.appendChild(createLanguageBadge("Code"));
      }

      header.appendChild(meta);
      return header;
    }

    function getCodeIcon() {
      return `
        <svg aria-hidden="true" class="code-block-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="m8 9-3 3 3 3"></path>
          <path d="m16 9 3 3-3 3"></path>
          <path d="m14 5-4 14"></path>
        </svg>
      `;
    }

    function getCopyButtonContent(label, copied = false) {
      const icon = copied
        ? `<path d="m5 12 4 4L19 6"></path>`
        : `<rect x="9" y="9" width="11" height="11" rx="2"></rect>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>`;

      return `
        <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          ${icon}
        </svg>
        <span class="sr-only">${label}</span>
      `;
    }

    async function copyCode(block, button) {
      const code = block.querySelector("code");
      const text = code?.innerText;

      await navigator.clipboard.writeText(text ?? "");

      button.innerHTML = getCopyButtonContent(copiedCodeLabel, true);
      button.ariaLabel = copiedCodeLabel;
      button.title = copiedCodeLabel;

      setTimeout(() => {
        button.innerHTML = getCopyButtonContent(copyButtonLabel);
        button.ariaLabel = copyButtonLabel;
        button.title = copyButtonLabel;
      }, 700);
    }
  }
  attachCopyButtons();
  runArticleEnterAnimation();

  function attachImageLightbox() {
    const article = document.querySelector("#article");
    const lightbox = document.querySelector("[data-image-lightbox]");
    const preview = lightbox?.querySelector("[data-lightbox-image]");
    const caption = lightbox?.querySelector("[data-lightbox-caption]");
    const prevButton = lightbox?.querySelector("[data-lightbox-prev]");
    const nextButton = lightbox?.querySelector("[data-lightbox-next]");
    const closeButtons = Array.from(
      lightbox?.querySelectorAll("[data-lightbox-close]") ?? []
    );

    if (
      !(article instanceof HTMLElement) ||
      !(lightbox instanceof HTMLElement) ||
      !(preview instanceof HTMLImageElement) ||
      !(caption instanceof HTMLElement) ||
      !(prevButton instanceof HTMLButtonElement) ||
      !(nextButton instanceof HTMLButtonElement)
    ) {
      return;
    }

    const images = Array.from(article.querySelectorAll("img[src]")).filter(
      image => image instanceof HTMLImageElement
    );
    let currentIndex = 0;
    let previousFocus = null;

    for (const image of images) {
      if (!(image instanceof HTMLImageElement)) continue;
      image.classList.add("article-lightbox-image");
      image.tabIndex = 0;
      image.setAttribute("role", "button");
      image.setAttribute("aria-label", image.alt || openImageLabel);
      image.addEventListener("click", event => {
        event.preventDefault();
        openLightbox(images.indexOf(image));
      });
      image.addEventListener("keydown", event => {
        if (event.key !== "Enter" && event.key !== " ") return;
        event.preventDefault();
        openLightbox(images.indexOf(image));
      });
    }

    for (const button of closeButtons) {
      button.addEventListener("click", closeLightbox);
    }

    prevButton.addEventListener("click", () => showImage(currentIndex - 1));
    nextButton.addEventListener("click", () => showImage(currentIndex + 1));

    lightbox.addEventListener("keydown", event => {
      if (event.key === "Escape") {
        closeLightbox();
      } else if (event.key === "ArrowLeft") {
        showImage(currentIndex - 1);
      } else if (event.key === "ArrowRight") {
        showImage(currentIndex + 1);
      }
    });

    function openLightbox(index) {
      if (index < 0) return;
      previousFocus = document.activeElement;
      showImage(index);
      lightbox.hidden = false;
      document.documentElement.classList.add("has-image-lightbox");
      requestAnimationFrame(() => lightbox.focus());
    }

    function closeLightbox() {
      lightbox.hidden = true;
      document.documentElement.classList.remove("has-image-lightbox");

      if (previousFocus instanceof HTMLElement) {
        previousFocus.focus();
      }
    }

    function showImage(index) {
      currentIndex = (index + images.length) % images.length;
      const image = images[currentIndex];

      if (!(image instanceof HTMLImageElement)) return;

      preview.src = image.currentSrc || image.src;
      preview.alt = image.alt;

      const captionText = image.alt.trim();
      caption.textContent = captionText;
      caption.hidden = captionText.length === 0;

      const hasMultipleImages = images.length > 1;
      prevButton.hidden = !hasMultipleImages;
      nextButton.hidden = !hasMultipleImages;
    }
  }
  attachImageLightbox();

  document.addEventListener("astro:after-swap", () => {
    window.scrollTo({ left: 0, top: 0, behavior: "instant" });
  });
</script>
