---
import type { MarkdownLayoutProps } from "astro";
import SiteTopbar from "@/components/SiteTopbar.astro";
import PageHeader from "@/components/PageHeader.astro";
import Layout from "./Layout.astro";
import { SITE } from "@/config";

type Props = MarkdownLayoutProps<{ title: string; headingEyebrow?: string }>;

const { frontmatter } = Astro.props;
---

<Layout title={`${frontmatter.title} | ${SITE.title}`}>
  <SiteTopbar />
  <main id="main-content" class="mx-auto max-w-4xl px-4 pb-14">
    <PageHeader title={frontmatter.title} />
    <section id="about" class="app-prose prose-img:border-0 prose-p:font-normal prose-p:text-gray-600 prose-p:leading-relaxed prose-li:font-normal prose-li:text-gray-600">
        <div class="*:first:mt-0">
          <slot />
        </div>
      </section>
    </main>
</Layout>
