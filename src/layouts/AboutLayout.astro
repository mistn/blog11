---
import type { MarkdownLayoutProps } from "astro";
import Footer from "@/components/Footer.astro";
import SiteTopbar from "@/components/SiteTopbar.astro";
import Layout from "./Layout.astro";
import { SITE } from "@/config";

type Props = MarkdownLayoutProps<{ title: string }>;

const { frontmatter } = Astro.props;
---

<Layout title={`${frontmatter.title} | ${SITE.title}`}>
  <SiteTopbar />
  <div transition:name="page-body">
    <main id="main-content" class="app-layout pb-14 lg:max-w-5xl">
      <section
        id="about"
        class="app-prose px-1 py-4 sm:px-2 sm:py-5 prose-img:border-0"
      >
        <h1
          class="[font-family:var(--font-ui-serif)] text-[2.2rem] tracking-tight sm:text-[2.6rem]"
        >
          {frontmatter.title}
        </h1>
        <slot />
      </section>
    </main>
  </div>
  <Footer />
</Layout>
