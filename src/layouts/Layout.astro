---
import { ClientRouter } from "astro:transitions";
import { PUBLIC_GOOGLE_SITE_VERIFICATION } from "astro:env/client";
import { SITE } from "@/config";
import { getLocaleFromPath, localizePath, ui, type Locale } from "@/i18n";
import "@/styles/global.css";

type StructuredDataType = "BlogPosting" | "CollectionPage" | "WebPage";

type Props = {
  title?: string;
  author?: string;
  profile?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  scrollSmooth?: boolean;
  structuredDataType?: StructuredDataType;
  structuredData?: Record<string, unknown> | null;
  locale?: Locale;
};

const locale = Astro.props.locale ?? getLocaleFromPath(Astro.url.pathname);
const copy = ui[locale];

const {
  title = SITE.title,
  author = SITE.author,
  profile = SITE.profile,
  description = copy.site.desc,
  ogImage = SITE.ogImage ? `/${SITE.ogImage}` : "/og.png",
  canonicalURL = new URL(Astro.url.pathname, Astro.url),
  pubDatetime,
  modDatetime,
  scrollSmooth = false,
  structuredDataType = pubDatetime ? "BlogPosting" : "WebPage",
  structuredData,
} = Astro.props;

const socialImageURL = new URL(ogImage, Astro.url);
const canonicalHref = canonicalURL.toString();
const zhURL = new URL(localizePath(Astro.url.pathname, "zh"), Astro.site);
const enURL = new URL(localizePath(Astro.url.pathname, "en"), Astro.site);
const ogType = structuredDataType === "BlogPosting" ? "article" : "website";
const person = {
  "@type": "Person",
  name: `${author}`,
  ...(profile && { url: profile }),
};

const baseStructuredData =
  structuredDataType === "BlogPosting"
    ? {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        headline: `${title}`,
        description: `${description}`,
        image: `${socialImageURL}`,
        url: canonicalHref,
        datePublished: pubDatetime?.toISOString(),
        ...(modDatetime && { dateModified: modDatetime.toISOString() }),
        author: [person],
      }
    : {
        "@context": "https://schema.org",
        "@type": structuredDataType,
        name: `${title}`,
        description: `${description}`,
        url: canonicalHref,
        image: `${socialImageURL}`,
        inLanguage: locale === "en" ? "en" : "zh-CN",
        isPartOf: {
          "@type": "WebSite",
          name: SITE.title,
          url: SITE.website,
        },
        author: [person],
      };

const resolvedStructuredData = structuredData
  ? { ...baseStructuredData, ...structuredData }
  : baseStructuredData;
---

<!doctype html>
<html
  dir={SITE.dir}
  lang={locale === "en" ? "en" : "zh-CN"}
  class={`${scrollSmooth && "scroll-smooth"}`}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png?v=20260511" />
    <link
      rel="preload"
      as="image"
      href="/avatar.avif"
      type="image/avif"
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="image"
      href="/bg-light.avif"
      type="image/avif"
      media="(prefers-color-scheme: light)"
    />
    <link
      rel="preload"
      as="image"
      href="/bg-dark.avif"
      type="image/avif"
      media="(prefers-color-scheme: dark)"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.22/dist/katex.min.css"
    />
    <script
      is:inline
      defer
      src="https://umami.miuo.me/script.js"
      data-website-id="f27b869d-b507-45d9-ba10-48bfc25a9ae1"></script>
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="zh-CN" href={zhURL} />
    <link rel="alternate" hreflang="en" href={enURL} />
    <link rel="alternate" hreflang="x-default" href={zhURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- General Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />

    <!-- Article Published/Modified time -->
    {
      structuredDataType === "BlogPosting" && pubDatetime && (
        <meta
          property="article:published_time"
          content={pubDatetime.toISOString()}
        />
      )
    }
    {
      structuredDataType === "BlogPosting" && modDatetime && (
        <meta
          property="article:modified_time"
          content={modDatetime.toISOString()}
        />
      )
    }

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />

    <!-- Google JSON-LD Structured data -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(resolvedStructuredData)}
    />

    <!-- Enable RSS feed auto-discovery  -->
    <!-- https://docs.astro.build/en/recipes/rss/#enabling-rss-feed-auto-discovery -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.title}
      href={new URL("rss.xml", Astro.site)}
    />

    <meta name="theme-color" content="" />

    {
      PUBLIC_GOOGLE_SITE_VERIFICATION && (
        <meta
          name="google-site-verification"
          content={PUBLIC_GOOGLE_SITE_VERIFICATION}
        />
      )
    }

    <script is:inline>
      (function () {
        const LOCALE_STORAGE_KEY = "preferred-locale";
        const EN_PREFIX = "/en";
        const pathname = window.location.pathname;
        const isEnglishPath =
          pathname === EN_PREFIX || pathname.startsWith(`${EN_PREFIX}/`);

        function getStoredLocale() {
          try {
            return localStorage.getItem(LOCALE_STORAGE_KEY);
          } catch {
            return null;
          }
        }

        function setStoredLocale(locale) {
          try {
            localStorage.setItem(LOCALE_STORAGE_KEY, locale);
          } catch {
            // Ignore storage restrictions and fall back to browser language.
          }
        }

        function toEnglishPath(path) {
          if (path === "/") return "/en/";
          if (path === "/404.html") return "/en/404/";
          return `${EN_PREFIX}${path}`;
        }

        function prefersEnglish() {
          const languages =
            navigator.languages?.length > 0
              ? navigator.languages
              : [navigator.language || ""];
          const supportedLanguage = languages
            .map(language => language.toLowerCase())
            .find(language => language.startsWith("zh") || language.startsWith("en"));

          if (supportedLanguage) return supportedLanguage.startsWith("en");
          return true;
        }

        if (isEnglishPath) {
          setStoredLocale("en");
        } else {
          const storedLocale = getStoredLocale();
          const shouldUseEnglish =
            storedLocale === "en" || (!storedLocale && prefersEnglish());

          if (shouldUseEnglish) {
            window.location.replace(
              `${toEnglishPath(pathname)}${window.location.search}${window.location.hash}`
            );
          }
        }

        document.addEventListener("click", event => {
          const target =
            event.target instanceof Element
              ? event.target.closest("[data-locale-target]")
              : null;

          if (!(target instanceof HTMLElement)) return;

          const targetLocale = target.dataset.localeTarget;
          if (targetLocale === "zh" || targetLocale === "en") {
            setStoredLocale(targetLocale);
          }
        });
      })();
    </script>

    <script is:inline>
      (function () {
        const shouldSkip = sessionStorage.getItem("skipViewTransition");
        if (shouldSkip) {
          document.documentElement.classList.add("skip-view-transition");
        }

        document.addEventListener("astro:page-load", () => {
          if (!shouldSkip) return;
          sessionStorage.removeItem("skipViewTransition");
          document.documentElement.classList.remove("skip-view-transition");
        });
      })();
    </script>

    <ClientRouter />

    <script is:inline>
      (function () {
        const initialColorScheme = "";
        const currentTheme = localStorage.getItem("theme");

        function getPreferTheme() {
          if (currentTheme) return currentTheme;
          if (initialColorScheme) return initialColorScheme;
          return window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        }

        const themeValue = getPreferTheme();
        document.firstElementChild?.setAttribute("data-theme", themeValue);

        window.theme = {
          themeValue: themeValue,
          getTheme: () => window.theme.themeValue,
          setTheme: val => {
            window.theme.themeValue = val;
          },
        };
      })();
    </script>
  </head>
  <body>
    <slot />

    <script src="../scripts/theme.ts"></script>
    <script src="../scripts/back-button-fallback.ts"></script>
    <script is:inline>
      const POST_MEMORY_KEY = "postLinkMemory";
      const POST_MEMORY_INIT_KEY = "__postLinkMemoryInit";

      function normalizePath(pathname, search = "") {
        const normalizedPath =
          pathname.length > 1 && pathname.endsWith("/")
            ? pathname.slice(0, -1)
            : pathname;
        return `${normalizedPath}${search}`;
      }

      function getCurrentPath() {
        return normalizePath(
          window.location.pathname,
          window.location.search
        );
      }

      function getListMemoryScope() {
        return document.querySelector("[data-post-memory-scope]");
      }

      function isRememberablePostLink(link) {
        if (!(link instanceof HTMLAnchorElement)) return false;

        const url = new URL(link.href, window.location.href);
        if (url.origin !== window.location.origin) return false;

        const currentUrl = new URL(window.location.href);
        const isSameDocumentLink =
          url.pathname === currentUrl.pathname &&
          url.search === currentUrl.search &&
          url.hash;

        if (isSameDocumentLink) return false;

        return (
          link.hasAttribute("data-post-link") ||
          url.pathname.startsWith("/posts/")
        );
      }

      function rememberPostLinkPosition(event) {
        if (
          event.defaultPrevented ||
          event.button !== 0 ||
          event.metaKey ||
          event.ctrlKey ||
          event.shiftKey ||
          event.altKey
        ) {
          return;
        }

        if (!getListMemoryScope()) return;

        const target =
          event.target instanceof Element
            ? event.target
            : event.target?.parentElement;
        const link = target?.closest("a[href]");
        if (!(link instanceof HTMLAnchorElement)) return;
        if (!isRememberablePostLink(link)) return;

        const url = new URL(link.href, window.location.href);

        sessionStorage.setItem(
          POST_MEMORY_KEY,
          JSON.stringify({
            listPath: getCurrentPath(),
            postPath: normalizePath(url.pathname, url.search),
            viewportTop: link.getBoundingClientRect().top,
            scrollY: window.scrollY,
          })
        );
      }

      function restorePostLinkPosition() {
        if (!getListMemoryScope()) return;

        const raw = sessionStorage.getItem(POST_MEMORY_KEY);
        if (!raw) return;

        try {
          const memory = JSON.parse(raw);
          if (memory?.listPath !== getCurrentPath()) return;

          document.documentElement.classList.add("is-restoring-scroll");

          const links = Array.from(document.querySelectorAll("a[href]")).filter(
            link => isRememberablePostLink(link)
          );
          const matchingLink = links.find(link => {
            if (!(link instanceof HTMLAnchorElement)) return false;
            const url = new URL(link.href, window.location.href);
            return normalizePath(url.pathname, url.search) === memory.postPath;
          });

          const targetTop =
            matchingLink instanceof HTMLElement
              ? window.scrollY +
                matchingLink.getBoundingClientRect().top -
                Number(memory.viewportTop ?? 0)
              : Number(memory.scrollY ?? 0);

          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              window.scrollTo({
                top: Math.max(0, targetTop),
                left: 0,
                behavior: "instant",
              });
              requestAnimationFrame(() => {
                document.documentElement.classList.remove("is-restoring-scroll");
              });
            });
          });

          sessionStorage.removeItem(POST_MEMORY_KEY);
        } catch {
          sessionStorage.removeItem(POST_MEMORY_KEY);
          document.documentElement.classList.remove("is-restoring-scroll");
        }
      }

      if (!window[POST_MEMORY_INIT_KEY]) {
        document.addEventListener("click", rememberPostLinkPosition);
        document.addEventListener("astro:page-load", restorePostLinkPosition);
        window[POST_MEMORY_INIT_KEY] = true;
      }

      restorePostLinkPosition();
    </script>
  </body>
</html>
