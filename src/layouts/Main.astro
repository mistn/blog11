---
import SiteTopbar from "@/components/SiteTopbar.astro";
import { SITE } from "@/config";

type Props = {
  pageTitle: string;
  pageDesc?: string;
};

const { pageTitle, pageDesc } = Astro.props;

const backUrl = SITE.showBackButton ? Astro.url.pathname : "/";
---

<SiteTopbar />
<div>
  <main
    data-backUrl={backUrl}
    data-post-memory-scope="list"
    id="main-content"
    class="app-layout pb-12 lg:max-w-5xl"
  >
    <div class="px-1 py-4 sm:px-2 sm:py-5">
      <h1
        class="[font-family:var(--font-ui-serif)] text-[2.2rem] leading-[1.12] font-semibold tracking-tight sm:text-[2.6rem]"
      >
        {pageTitle}
      </h1>
      {
        pageDesc && (
          <p class="mt-4 mb-10 max-w-3xl text-[1rem] leading-8 text-foreground/60">
            {pageDesc}
          </p>
        )
      }
      <slot />
    </div>
  </main>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const mainContent: HTMLElement | null =
      document.querySelector("#main-content");
    const backUrl = mainContent?.dataset?.backurl;
    if (backUrl) {
      sessionStorage.setItem("backUrl", backUrl);
    }
  });
</script>
