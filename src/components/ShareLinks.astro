---
const postUrl = Astro.url.href;
---

<div class="flex items-center justify-start">
  <button
    type="button"
    data-copy-post-link={postUrl}
    class="text-[0.98rem] text-foreground/58 underline decoration-border decoration-1 underline-offset-4 transition hover:text-accent"
  >
    复制文章链接
  </button>
</div>

<script is:inline>
  function setupCopyPostLink() {
    const copyButton = document.querySelector("[data-copy-post-link]");
    if (!(copyButton instanceof HTMLButtonElement)) return;

    copyButton.addEventListener("click", async () => {
      const link = copyButton.dataset.copyPostLink ?? window.location.href;
      await navigator.clipboard.writeText(link);

      copyButton.textContent = "链接已复制";

      window.setTimeout(() => {
        copyButton.textContent = "复制文章链接";
      }, 1000);
    });
  }

  document.addEventListener("astro:page-load", setupCopyPostLink);
  setupCopyPostLink();
</script>
