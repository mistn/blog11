---
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import { getLocaleFromPath, ui, type Locale } from "@/i18n";

type Props = {
  locale?: Locale;
};

const { locale = getLocaleFromPath(Astro.url.pathname) } = Astro.props;
const copy = ui[locale];
---

<div
  id="btt-btn-container"
  class:list={[
    "fixed end-5 bottom-6 z-50",
    "translate-y-14 opacity-0 transition duration-300",
  ]}
>
  <button
    data-button="back-to-top"
    style="--read-progress-ratio: 0;"
    class:list={[
      "group relative flex size-11 items-center justify-center rounded-full text-foreground/70 transition hover:text-accent",
    ]}
    aria-label={copy.actions.backToTop}
    title={copy.actions.backToTop}
  >
    <svg
      aria-hidden="true"
      viewBox="0 0 44 44"
      class="pointer-events-none absolute inset-0 size-full -rotate-90"
    >
      <circle
        cx="22"
        cy="22"
        r="20.5"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        class="text-accent"
        style="stroke-dasharray: 128.8; stroke-dashoffset: calc(128.8 - (128.8 * var(--read-progress-ratio)));"
      />
    </svg>
    <span
      class="relative flex size-full items-center justify-center rounded-full"
    >
      <IconChevronLeft
        class="inline-block size-4 rotate-90 transition group-hover:-translate-y-0.5"
      />
    </span>
  </button>
</div>

<script is:inline data-astro-rerun>
  function backToTop() {
    const rootElement = document.documentElement;
    const btnContainer = document.querySelector("#btt-btn-container");
    const backToTopBtn = document.querySelector("[data-button='back-to-top']");

    if (!rootElement || !btnContainer || !backToTopBtn) return;

    backToTopBtn.addEventListener("click", () => {
      document.body.scrollTop = 0;
      document.documentElement.scrollTop = 0;
    });

    let lastVisible = null;
    function handleScroll() {
      const scrollTotal = rootElement.scrollHeight - rootElement.clientHeight;
      const scrollTop = rootElement.scrollTop;
      const safeScrollTotal = scrollTotal <= 0 ? 1 : scrollTotal;
      const progress = Math.min(Math.max(scrollTop / safeScrollTotal, 0), 1);

      backToTopBtn.style.setProperty(
        "--read-progress-ratio",
        progress.toFixed(4)
      );

      const isVisible = progress > 0.18;

      if (isVisible !== lastVisible) {
        btnContainer.classList.toggle("opacity-100", isVisible);
        btnContainer.classList.toggle("translate-y-0", isVisible);
        btnContainer.classList.toggle("opacity-0", !isVisible);
        btnContainer.classList.toggle("translate-y-14", !isVisible);
        lastVisible = isVisible;
      }
    }

    let ticking = false;
    document.addEventListener("scroll", () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          handleScroll();
          ticking = false;
        });
        ticking = true;
      }
    });

    handleScroll();
  }
  backToTop();
</script>
