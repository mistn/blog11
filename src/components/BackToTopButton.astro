---
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import { getLocaleFromPath, ui, type Locale } from "@/i18n";

type Props = {
  locale?: Locale;
};

const { locale = getLocaleFromPath(Astro.url.pathname) } = Astro.props;
const copy = ui[locale];
---

<button
  id="btt-btn"
  data-button="back-to-top"
  class="flex size-11 items-center justify-center rounded-full border border-gray-200 bg-white/80 shadow-lg backdrop-blur-md opacity-0 pointer-events-none transition-all duration-300 hover:shadow-xl dark:border-gray-700 dark:bg-gray-800/80"
  aria-label={copy.actions.backToTop}
  title={copy.actions.backToTop}
>
  <IconChevronLeft class="size-4 rotate-90 text-gray-700 dark:text-gray-200" />
</button>

<script is:inline data-astro-rerun>
  (function () {
    const btn = document.getElementById("btt-btn");
    if (!btn) return;

    if (btn.dataset.bttBound === "true") return;
    btn.dataset.bttBound = "true";

    btn.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });

    const THRESHOLD = 300;
    let lastVisible = false;

    function handleScroll() {
      const isVisible = window.scrollY > THRESHOLD;
      if (isVisible === lastVisible) return;
      lastVisible = isVisible;

      btn.classList.toggle("opacity-100", isVisible);
      btn.classList.toggle("pointer-events-auto", isVisible);
      btn.classList.toggle("opacity-0", !isVisible);
      btn.classList.toggle("pointer-events-none", !isVisible);
    }

    let ticking = false;
    window.addEventListener("scroll", () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          handleScroll();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    handleScroll();
  })();
</script>
