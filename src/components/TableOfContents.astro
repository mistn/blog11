---
import IconListTree from "@/assets/icons/IconListTree.svg";
import IconX from "@/assets/icons/IconX.svg";
import { getLocaleFromPath, ui, type Locale } from "@/i18n";

type Heading = {
  depth: number;
  slug: string;
  text: string;
};

type Props = {
  headings: Heading[];
  locale?: Locale;
};

const { headings, locale = getLocaleFromPath(Astro.url.pathname) } =
  Astro.props;

const copy = ui[locale];

const tocHeadings = headings.filter(
  heading => heading.depth >= 2 && heading.depth <= 4 && heading.slug
);

const title = copy.actions.tocTitle;
const toggleLabel = copy.actions.tocToggle;
const closeLabel = copy.actions.tocClose;
---

{
  tocHeadings.length > 0 && (
    <div
      id="toc-drawer"
      data-toc-root
      data-open="false"
      class="pointer-events-none fixed end-5 bottom-6 z-50"
    >
      <aside
        aria-labelledby="toc-drawer-title"
        data-toc-panel
        class="pointer-events-none fixed inset-x-3 bottom-20 flex max-h-[min(28rem,72svh)] translate-y-3 flex-col rounded-md border border-border/70 bg-background/96 px-4 pt-4 pb-[calc(1rem+env(safe-area-inset-bottom))] opacity-0 shadow-[0_18px_48px_rgba(15,23,42,0.16)] backdrop-blur-xl transition duration-200 ease-out sm:inset-x-auto sm:end-5 sm:bottom-28 sm:max-h-[min(30rem,62vh)] sm:w-[min(20rem,calc(100vw-2.5rem))] sm:translate-y-2 sm:pb-4"
      >
        <div class="flex items-center justify-between gap-3">
          <h2
            id="toc-drawer-title"
            class="text-lg font-medium"
          >
            {title}
          </h2>
          <button
            type="button"
            data-toc-close
            aria-label={closeLabel}
            title={closeLabel}
            class="flex size-9 items-center justify-center rounded-full border border-border/70 bg-muted/60 text-foreground/72 transition hover:text-accent"
          >
            <IconX class="size-4" />
          </button>
        </div>

        <nav
          data-toc-nav
          class="mt-4 min-h-0 overflow-y-auto pe-1"
          aria-label={title}
        >
          <ol class="space-y-1">
            {tocHeadings.map(heading => (
              <li>
                <a
                  href={`#${heading.slug}`}
                  data-toc-link={heading.slug}
                  class:list={[
                    "block rounded px-2 py-2 text-sm leading-6 text-foreground/70 transition hover:bg-muted/70 hover:text-accent sm:py-1.5",
                    {
                      "ms-3": heading.depth === 3,
                      "ms-6 text-xs": heading.depth === 4,
                    },
                  ]}
                >
                  {heading.text}
                </a>
              </li>
            ))}
          </ol>
        </nav>
      </aside>

      <div class="pointer-events-auto">
        <button
          type="button"
          data-toc-toggle
          aria-expanded="false"
          aria-controls="toc-drawer"
          aria-label={toggleLabel}
          title={title}
          class="group flex size-11 items-center justify-center rounded-full border border-border/70 bg-background/90 text-foreground/70 shadow-[0_8px_24px_rgba(15,23,42,0.08)] backdrop-blur-sm transition hover:text-accent"
        >
          <IconListTree class="size-5 transition group-hover:scale-105" />
        </button>
      </div>
    </div>
  )
}

<script is:inline data-astro-rerun>
  function initTableOfContents() {
    const root = document.querySelector("[data-toc-root]");
    if (!root) return;

    const toggle = root.querySelector("[data-toc-toggle]");
    const close = root.querySelector("[data-toc-close]");
    const panel = root.querySelector("[data-toc-panel]");
    const nav = root.querySelector("[data-toc-nav]");
    const links = Array.from(root.querySelectorAll("[data-toc-link]"));
    const targets = links
      .map(link => {
        const id = link.getAttribute("data-toc-link");
        return id ? document.getElementById(id) : null;
      })
      .filter(Boolean);

    if (!toggle || !close || !panel || !nav) return;

    let activeId = null;

    function scrollLinkIntoView(link) {
      const navRect = nav.getBoundingClientRect();
      const linkRect = link.getBoundingClientRect();
      const isAbove = linkRect.top < navRect.top;
      const isBelow = linkRect.bottom > navRect.bottom;

      if (!isAbove && !isBelow) return;

      link.scrollIntoView({
        block: "nearest",
        behavior: "smooth",
      });
    }

    function setOpen(isOpen) {
      root.dataset.open = String(isOpen);
      toggle.setAttribute("aria-expanded", String(isOpen));
      root.classList.toggle("pointer-events-auto", isOpen);
      root.classList.toggle("pointer-events-none", !isOpen);
      panel.classList.toggle("pointer-events-auto", isOpen);
      panel.classList.toggle("pointer-events-none", !isOpen);
      panel.classList.toggle("translate-y-0", isOpen);
      panel.classList.toggle("translate-y-3", !isOpen);
      panel.classList.toggle("sm:translate-y-2", !isOpen);
      panel.classList.toggle("opacity-100", isOpen);
      panel.classList.toggle("opacity-0", !isOpen);

      if (isOpen) {
        window.requestAnimationFrame(() => updateActiveLink({ scroll: true }));
      }
    }

    function updateActiveLink(options = {}) {
      let nextActiveId = targets[0]?.id;
      for (const target of targets) {
        if (target.getBoundingClientRect().top <= 120) {
          nextActiveId = target.id;
        } else {
          break;
        }
      }

      let activeLink = null;
      for (const link of links) {
        const isActive = link.getAttribute("data-toc-link") === nextActiveId;
        link.classList.toggle("bg-muted", isActive);
        link.classList.toggle("text-accent", isActive);
        link.classList.toggle("font-medium", isActive);
        if (isActive) activeLink = link;
      }

      const shouldScroll =
        activeLink &&
        root.dataset.open === "true" &&
        (options.scroll || nextActiveId !== activeId);

      activeId = nextActiveId;

      if (shouldScroll) {
        scrollLinkIntoView(activeLink);
      }
    }

    toggle.addEventListener("click", event => {
      event.stopPropagation();
      setOpen(root.dataset.open !== "true");
    });
    close.addEventListener("click", event => {
      event.stopPropagation();
      setOpen(false);
    });
    links.forEach(link => link.addEventListener("click", event => {
      event.stopPropagation();
      setOpen(false);
    }));
    document.addEventListener("click", event => {
      if (root.dataset.open !== "true") return;
      if (event.target instanceof Node && root.contains(event.target)) return;
      setOpen(false);
    });
    document.addEventListener("keydown", event => {
      if (event.key === "Escape") setOpen(false);
    });

    let ticking = false;
    document.addEventListener("scroll", () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          updateActiveLink();
          ticking = false;
        });
        ticking = true;
      }
    });

    updateActiveLink();
  }

  initTableOfContents();
</script>
