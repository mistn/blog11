---
interface Props {
  code: string;
  language?: string;
}

const { code, language = "yaml" } = Astro.props;
---

<div class="code-block-frame group relative my-6 rounded-xl border border-gray-200 bg-gray-50/50 dark:border-gray-800 dark:bg-gray-900/50">
  <div class="flex items-center justify-between px-4 py-2 border-b border-gray-200 dark:border-gray-800">
    <div class="flex items-center gap-2">
      <svg aria-hidden="true" class="size-3.5 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="m8 9-3 3 3 3"></path>
        <path d="m16 9 3 3-3 3"></path>
        <path d="m14 5-4 14"></path>
      </svg>
      <span class="text-xs font-medium text-gray-500 uppercase dark:text-gray-400">{language}</span>
    </div>
    <button
      type="button"
      class="text-xs text-gray-400 hover:text-gray-900 dark:hover:text-gray-200 transition-colors"
      aria-label="复制代码"
      title="复制代码"
      data-code-snippet-value={code}
    >
      Copy
    </button>
  </div>
  <div class="overflow-x-auto p-4">
    <pre class="font-mono text-sm leading-relaxed text-gray-800 dark:text-gray-200"><code>{code}</code></pre>
  </div>
</div>

<script>
  function initCodeSnippets() {
    document.querySelectorAll("[data-code-snippet-value]").forEach((btn) => {
      if (!(btn instanceof HTMLButtonElement)) return;
      if (btn.dataset.snippetBound === "true") return;
      btn.dataset.snippetBound = "true";

      btn.addEventListener("click", async () => {
        const value = btn.dataset.codeSnippetValue;
        if (!value) return;

        const originalText = btn.textContent;
        try {
          await navigator.clipboard.writeText(value);
          btn.textContent = "Copied!";
          window.setTimeout(() => {
            btn.textContent = originalText;
          }, 700);
        } catch {
          btn.textContent = "Failed";
          window.setTimeout(() => {
            btn.textContent = originalText;
          }, 700);
        }
      });
    });
  }

  document.addEventListener("astro:page-load", initCodeSnippets);
  initCodeSnippets();
</script>
