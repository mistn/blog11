---
import type { Locale } from "@/i18n";

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;

const labels =
  locale === "en"
    ? {
        dialog: "Image preview",
        close: "Close image preview",
        previous: "Previous image",
        next: "Next image",
      }
    : {
        dialog: "图片预览",
        close: "关闭图片预览",
        previous: "上一张图片",
        next: "下一张图片",
      };
---

<div
  class="image-lightbox"
  data-image-lightbox
  hidden
  role="dialog"
  aria-modal="true"
  aria-label={labels.dialog}
  tabindex="-1"
>
  <button
    class="image-lightbox__backdrop"
    type="button"
    data-lightbox-close
    aria-label={labels.close}
  >
  </button>
  <figure class="image-lightbox__figure">
    <img data-lightbox-image alt="" />
    <figcaption data-lightbox-caption hidden></figcaption>
  </figure>
  <button
    class="image-lightbox__control image-lightbox__control--prev"
    type="button"
    data-lightbox-prev
    aria-label={labels.previous}
  >
    <svg
      aria-hidden="true"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.4"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="m15 18-6-6 6-6"></path>
    </svg>
  </button>
  <button
    class="image-lightbox__control image-lightbox__control--next"
    type="button"
    data-lightbox-next
    aria-label={labels.next}
  >
    <svg
      aria-hidden="true"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.4"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="m9 18 6-6-6-6"></path>
    </svg>
  </button>
  <button
    class="image-lightbox__close"
    type="button"
    data-lightbox-close
    aria-label={labels.close}
  >
    <svg
      aria-hidden="true"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.4"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M18 6 6 18"></path>
      <path d="m6 6 12 12"></path>
    </svg>
  </button>
</div>
