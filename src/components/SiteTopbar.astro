---
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import HomeTabs from "@/components/HomeTabs.astro";
import LinkButton from "@/components/LinkButton.astro";
import { SITE } from "@/config";
---

<section transition:persist class="app-layout py-6 lg:max-w-7xl lg:py-8">
  <div class="border-b border-border/70 px-1 pb-4 sm:px-2">
    <div
      class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between"
    >
      <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:gap-10">
        <div class="min-w-0">
          <p
            class="[font-family:var(--font-ui-serif)] text-[1.85rem] leading-none font-semibold tracking-tight"
          >
            {SITE.author}
          </p>
          <p class="mt-2 text-[0.92rem] leading-6 text-foreground/56 lg:hidden">
            {SITE.desc}
          </p>
        </div>

        <HomeTabs />
      </div>

      <div class="flex items-center gap-1 self-end lg:self-auto">
        <LinkButton
          href="/search"
          class="focus-outline flex size-10 items-center justify-center rounded-full text-foreground/68 transition hover:text-accent"
          title="Search"
          aria-label="search"
        >
          <IconSearch class="size-5" />
          <span class="sr-only">Search</span>
        </LinkButton>

        {
          SITE.lightAndDarkMode && (
            <button
              id="theme-btn"
              class="focus-outline relative size-10 rounded-full text-foreground/68 transition hover:text-accent"
              title="Toggles light & dark"
              aria-label="auto"
              aria-live="polite"
            >
              <IconMoon class="absolute top-[50%] left-[50%] size-5 -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
              <IconSunHigh class="absolute top-[50%] left-[50%] size-5 -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
            </button>
          )
        }
      </div>
    </div>
  </div>
</section>
