---
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import { SITE } from "@/config";
---

<section transition:persist class="app-layout py-6 lg:max-w-7xl lg:py-8">
  <div class="px-1 pb-4 sm:px-2">
    <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
      <div class="flex items-start gap-4 sm:gap-5">
        <div class="h-20 w-20 overflow-hidden rounded-full border border-border/80 sm:h-24 sm:w-24">
          <img
            src="/avatar.avif"
            alt={`${SITE.author} avatar`}
            class="h-full w-full object-cover"
            loading="eager"
          />
        </div>
        <div class="min-w-0">
          <p class="text-[11px] uppercase tracking-[0.28em] text-foreground/45">{SITE.title}</p>
          <a
            href="/"
            class="mt-2 inline-block text-[2rem] leading-none font-semibold tracking-tight transition hover:text-accent"
          >
            {SITE.author}
          </a>
          <p class="mt-3 max-w-xl text-sm leading-7 text-foreground/70">{SITE.desc}</p>
        </div>
      </div>

      {SITE.lightAndDarkMode && (
        <div class="flex items-center self-end">
          <button
            id="theme-btn"
            class="focus-outline relative size-10 p-2.5 hover:[&>svg]:stroke-accent sm:size-12 sm:p-3"
            title="Toggles light & dark"
            aria-label="auto"
            aria-live="polite"
          >
            <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
            <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
          </button>
        </div>
      )}
    </div>
  </div>
</section>
