---
import IconMail from "@/assets/icons/IconMail.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconLanguage from "@/assets/icons/IconLanguage.svg";
import IconRss from "@/assets/icons/IconRss.svg";
import HomeTabs from "@/components/HomeTabs.astro";
import LinkButton from "@/components/LinkButton.astro";
import { SOCIALS } from "@/constants";
import { SITE } from "@/config";
import {
  getAlternateLocale,
  getLocaleFromPath,
  localizePath,
  normalizePath,
  ui,
} from "@/i18n";

type Props = {
  compactMobile?: boolean;
};

const { compactMobile = false } = Astro.props;

const locale = getLocaleFromPath(Astro.url.pathname);
const copy = ui[locale];
const alternateLocale = getAlternateLocale(locale);
const languageHref = localizePath(Astro.url.pathname, alternateLocale);
const emailLink = SOCIALS.find(social => social.href.startsWith("mailto:"));
const emailAddress = emailLink?.href.replace("mailto:", "");
const emailLabel = `${copy.nav.email} ${SITE.title}`;

const getHref = (path: string) => localizePath(path, locale);
const currentPath = normalizePath(Astro.url.pathname);
const isActive = (path: string) => currentPath === normalizePath(getHref(path));
---

<!-- ===== Topbar ===== -->
<section
  class:list={[
    "app-layout lg:py-8",
    compactMobile ? "py-4" : "py-6",
  ]}
>
    <div
      class:list={[
        "px-1 sm:px-2 font-app",
        compactMobile ? "pb-3" : "pb-4",
      ]}
    >
      <div class="flex items-center justify-between">
        <!-- Left: Logo -->
        <div class="min-w-0">
          <p class="-ml-[2px] text-[1.85rem] leading-none font-medium tracking-tight">
            {SITE.author}
          </p>
        </div>

      <!-- Desktop: HomeTabs + icons -->
      <div class="hidden lg:flex lg:items-center lg:gap-10">
        <HomeTabs />

        <div class="flex items-center gap-1">
          <LinkButton
            href={localizePath("/search", locale)}
            class="focus-outline flex size-10 items-center justify-center rounded-full text-foreground/68 transition hover:text-accent"
            title={copy.nav.search}
            aria-label={copy.nav.search}
          >
            <IconSearch class="size-5" />
            <span class="sr-only">{copy.nav.search}</span>
          </LinkButton>

          <a
            href="/rss.xml"
            class="focus-outline flex size-10 items-center justify-center rounded-full text-foreground/68 transition hover:text-accent"
            title="RSS"
            aria-label="RSS"
          >
            <IconRss class="size-5" />
            <span class="sr-only">RSS</span>
          </a>

          <a
            href={languageHref}
            data-locale-target={alternateLocale}
            data-astro-reload
            class="group inline-flex size-10 items-center justify-center gap-1 rounded-full text-foreground/68 transition focus-outline hover:text-accent"
            title={copy.nav.languageLabel}
            aria-label={copy.nav.languageLabel}
          >
            <IconLanguage class="size-5" />
            <span class="sr-only">{copy.nav.languageLabel}</span>
          </a>

          {
            SITE.lightAndDarkMode && (
              <button
                id="theme-btn-desktop"
                class="focus-outline relative size-10 rounded-full text-foreground/68 transition hover:text-accent"
                title={copy.nav.theme}
                aria-label={copy.nav.theme}
                aria-live="polite"
              >
                <span
                  data-theme-icon-anchor
                  class="pointer-events-none absolute top-[50%] left-[50%] size-5 -translate-[50%]"
                  aria-hidden="true"
                >
                  <IconMoon class="absolute inset-0 h-full w-full scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                  <IconSunHigh class="absolute inset-0 h-full w-full scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
                </span>
              </button>
            )
          }
        </div>
      </div>

      <!-- Mobile: Hamburger -->
      <button
        id="menu-toggle"
        class="lg:hidden p-2 -mr-2 text-foreground/68 hover:text-foreground transition-colors"
        aria-label="Menu"
        aria-expanded="false"
      >
        <svg class="size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="4" y1="6" x2="20" y2="6" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="18" x2="20" y2="18" />
        </svg>
      </button>
    </div>
  </div>
</section>

<!-- ===== Mobile Full-screen Overlay ===== -->
<div
  id="mobile-overlay"
  class="fixed inset-0 bg-white dark:bg-background z-50 hidden flex-col justify-center items-center"
  aria-hidden="true"
>
  <!-- Close button -->
  <button
    id="menu-close"
    class="absolute top-6 right-6 p-2 text-gray-400 hover:text-gray-900 dark:text-gray-500 dark:hover:text-gray-100 transition-colors"
    aria-label="Close menu"
  >
    <svg class="size-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="6" y1="6" x2="18" y2="18" />
      <line x1="18" y1="6" x2="6" y2="18" />
    </svg>
  </button>

  <!-- Nav links -->
  <nav class="flex flex-col items-center space-y-6">
    <a
      href={getHref("/")}
      class:list={[
        "text-xl font-medium py-2 px-8 transition-colors",
        isActive("/")
          ? "text-gray-900 dark:text-gray-100 font-semibold"
          : "text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100",
      ]}
      data-overlay-link
    >
      {copy.nav.home}
    </a>
    {
      SITE.showArchives && (
        <a
          href={getHref("/archives")}
          class:list={[
            "text-xl font-medium py-2 px-8 transition-colors",
            isActive("/archives")
              ? "text-gray-900 dark:text-gray-100 font-semibold"
              : "text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100",
          ]}
          data-overlay-link
        >
          {copy.nav.archives}
        </a>
      )
    }
    <a
      href={getHref("/anime")}
      class:list={[
        "text-xl font-medium py-2 px-8 transition-colors",
        isActive("/anime")
          ? "text-gray-900 dark:text-gray-100 font-semibold"
          : "text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100",
      ]}
      data-overlay-link
    >
      {copy.nav.anime}
    </a>
    <a
      href={getHref("/friends")}
      class:list={[
        "text-xl font-medium py-2 px-8 transition-colors",
        isActive("/friends")
          ? "text-gray-900 dark:text-gray-100 font-semibold"
          : "text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100",
      ]}
      data-overlay-link
    >
      {copy.nav.friends}
    </a>
    <a
      href={getHref("/about")}
      class:list={[
        "text-xl font-medium py-2 px-8 transition-colors",
        isActive("/about")
          ? "text-gray-900 dark:text-gray-100 font-semibold"
          : "text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100",
      ]}
      data-overlay-link
    >
      {copy.nav.about}
    </a>
  </nav>

  <!-- Bottom icons -->
  <div class="absolute bottom-10 flex items-center gap-6">
    <a
      href={localizePath("/search", locale)}
      class="text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors"
      title={copy.nav.search}
      aria-label={copy.nav.search}
      data-overlay-link
    >
      <IconSearch class="size-6" />
    </a>

    {
      emailLink && emailAddress && (
        <a
          href={emailLink.href}
          class="text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors"
          title={emailLabel}
          aria-label={emailLabel}
        >
          <IconMail class="size-6" />
        </a>
      )
    }

    <a
      href="/rss.xml"
      class="text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors"
      title="RSS"
      aria-label="RSS"
    >
      <IconRss class="size-6" />
    </a>

    <a
      href={languageHref}
      data-locale-target={alternateLocale}
      data-astro-reload
      class="text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors"
      title={copy.nav.languageLabel}
      aria-label={copy.nav.languageLabel}
    >
      <IconLanguage class="size-6" />
    </a>

    {
      SITE.lightAndDarkMode && (
        <button
          id="theme-btn"
          class="text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors"
          title={copy.nav.theme}
          aria-label={copy.nav.theme}
          aria-live="polite"
        >
          <span data-theme-icon-anchor aria-hidden="true" class="inline-block size-6">
            <IconMoon class="hidden dark:block size-6" />
            <IconSunHigh class="block dark:hidden size-6" />
          </span>
        </button>
      )
    }
  </div>
</div>

<script is:inline>
  function getOverlay() { return document.getElementById("mobile-overlay"); }
  function getToggle() { return document.getElementById("menu-toggle"); }

  function openMenu() {
    var overlay = getOverlay();
    var toggle = getToggle();
    if (!overlay || !toggle) return;
    overlay.classList.remove("hidden");
    overlay.classList.add("flex");
    overlay.setAttribute("aria-hidden", "false");
    toggle.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  }

  function closeMenu() {
    var overlay = getOverlay();
    var toggle = getToggle();
    if (!overlay || !toggle) return;
    overlay.classList.add("hidden");
    overlay.classList.remove("flex");
    overlay.setAttribute("aria-hidden", "true");
    toggle.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
    toggle.focus();
  }

  function closeMenuSilent() {
    var overlay = getOverlay();
    var toggle = getToggle();
    if (!overlay) return;
    overlay.classList.add("hidden");
    overlay.classList.remove("flex");
    overlay.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
    if (toggle) toggle.setAttribute("aria-expanded", "false");
  }

  document.addEventListener("click", function (e) {
    var target = /** @type {HTMLElement} */ (e.target);

    if (target.closest("#menu-toggle")) {
      openMenu();
      return;
    }

    if (target.closest("#menu-close") || target.closest("[data-overlay-link]")) {
      closeMenu();
      return;
    }

    var overlay = getOverlay();
    if (overlay && e.target === overlay && overlay.getAttribute("aria-hidden") === "false") {
      closeMenu();
    }
  });

  document.addEventListener("keydown", function (e) {
    if (e.key === "Escape") {
      var overlay = getOverlay();
      if (overlay && overlay.getAttribute("aria-hidden") === "false") {
        closeMenu();
      }
    }
  });

  document.addEventListener("astro:before-swap", function () {
    closeMenuSilent();
  });
</script>
