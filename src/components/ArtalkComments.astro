---
import { getLocaleFromPath, ui } from "@/i18n";

type Props = {
  pageKey: string;
  pageTitle: string;
};

const { pageKey, pageTitle } = Astro.props;
const locale = getLocaleFromPath(Astro.url.pathname);
const copy = ui[locale];
const artalkIsEnglish = locale === "en";
const artalkText =
  artalkIsEnglish
    ? {
        counter: "{count} comments",
        email: "Email",
        link: "Website",
        nick: "Name",
        noComment: "No comments yet",
        placeholder: "Type something...",
        send: "Post",
        sendBtn: "Post",
      }
    : {
        counter: "{count} 条评论",
        email: "邮箱",
        link: "网址",
        nick: "昵称",
        noComment: "「此时无声胜有声」",
        placeholder: "键入内容...",
        send: "发送",
        sendBtn: "发送",
      };

const server = "https://artalkk.miuo.me";
const siteName = "blogs";
const containerId = `artalk-comments-${pageKey.replace(/[^a-zA-Z0-9_-]/g, "-")}`;
---

<section
  class="mt-10 border-t border-border/60 pt-8"
  data-pagefind-ignore
  aria-label={copy.actions.comments}
>
  <h2
    class="text-[1.65rem] font-medium tracking-tight"
  >
    {copy.actions.comments}
  </h2>
  <div id={containerId} class="mt-5 min-h-28"></div>
</section>

<script
  is:inline
  data-astro-rerun
  define:vars={{
    artalkIsEnglish,
    artalkText,
    containerId,
    pageKey,
    pageTitle,
    server,
    siteName,
  }}
>
  const ARTALK_CSS_URL =
    "https://cdnjs.cloudflare.com/ajax/libs/artalk/2.9.1/Artalk.css";
  const ARTALK_JS_URL = "https://esm.sh/artalk@2.9.1";
  const ARTALK_MOUNT_RETRY_LIMIT = 12;
  const ARTALK_EN_REPLACEMENTS = [
    ["昵称", "Name"],
    ["邮箱", "Email"],
    ["网址", "Website"],
    ["键入内容...", "Type something..."],
    ["发送", "Post"],
    ["条评论", "comments"],
    ["「此时无声胜有声」", "No comments yet"],
  ];

  function isDarkTheme() {
    return document.documentElement.getAttribute("data-theme") === "dark";
  }

  function ensureArtalkStyle() {
    if (document.querySelector('link[data-artalk-style="true"]')) return;

    const link = document.createElement("link");
    link.rel = "stylesheet";
    link.href = ARTALK_CSS_URL;
    link.dataset.artalkStyle = "true";
    document.head.appendChild(link);
  }

  async function mountArtalk() {
    const el = document.getElementById(containerId);
    if (!el) return;

    ensureArtalkStyle();

    if (window.__artalk?.destroy) {
      window.__artalk.destroy();
    }

    window.__artalkTextObserver?.disconnect();
    el.innerHTML = "";

    const { default: Artalk } = await import(ARTALK_JS_URL);

    window.__artalk = Artalk.init({
      el,
      server,
      site: siteName,
      pageKey,
      pageTitle,
      darkMode: isDarkTheme(),
      locale: {
        counter: artalkText.counter,
        email: artalkText.email,
        link: artalkText.link,
        nick: artalkText.nick,
        noComment: artalkText.noComment,
        placeholder: artalkText.placeholder,
        send: artalkText.send,
      },
      noComment: artalkText.noComment,
      placeholder: artalkText.placeholder,
      preferRemoteConf: false,
      sendBtn: artalkText.sendBtn,
    });

    setupArtalkTextFallback(el);
  }

  function replaceTextValue(value) {
    return ARTALK_EN_REPLACEMENTS.reduce(
      (text, [from, to]) => text.replaceAll(from, to),
      value
    );
  }

  function localizeArtalkDom(root) {
    if (!artalkIsEnglish) return;

    const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT);
    const textNodes = [];

    while (walker.nextNode()) {
      textNodes.push(walker.currentNode);
    }

    textNodes.forEach((node) => {
      const nextText = replaceTextValue(node.nodeValue ?? "");
      if (nextText !== node.nodeValue) node.nodeValue = nextText;
    });

    root.querySelectorAll("input, textarea, button").forEach((node) => {
      ["placeholder", "aria-label", "title", "value"].forEach((attr) => {
        const value = node.getAttribute(attr);
        if (!value) return;

        const nextValue = replaceTextValue(value);
        if (nextValue !== value) node.setAttribute(attr, nextValue);
      });
    });
  }

  function setupArtalkTextFallback(root) {
    if (!artalkIsEnglish) return;

    localizeArtalkDom(root);

    window.__artalkTextObserver?.disconnect();
    window.__artalkTextObserver = new MutationObserver(() => {
      localizeArtalkDom(root);
    });
    window.__artalkTextObserver.observe(root, {
      childList: true,
      subtree: true,
      characterData: true,
    });
  }

  function scheduleArtalkMount(retryCount = 0) {
    const el = document.getElementById(containerId);

    if (!el) {
      if (retryCount >= ARTALK_MOUNT_RETRY_LIMIT) return;

      requestAnimationFrame(() => {
        scheduleArtalkMount(retryCount + 1);
      });
      return;
    }

    void mountArtalk().then(() => {
      requestAnimationFrame(() => {
        syncArtalkTheme();
      });
    });
  }

  function syncArtalkTheme() {
    if (window.__artalk?.setDarkMode) {
      window.__artalk.setDarkMode(isDarkTheme());
    }
  }

  if (window.__artalkPageLoadHandler) {
    document.removeEventListener(
      "astro:page-load",
      window.__artalkPageLoadHandler
    );
    document.removeEventListener(
      "astro:after-swap",
      window.__artalkPageLoadHandler
    );
  }

  if (window.__artalkThemeHandler) {
    document.removeEventListener("theme-change", window.__artalkThemeHandler);
  }

  window.__artalkPageLoadHandler = () => {
    scheduleArtalkMount();
  };
  window.__artalkThemeHandler = syncArtalkTheme;

  document.addEventListener("astro:page-load", window.__artalkPageLoadHandler);
  document.addEventListener("astro:after-swap", window.__artalkPageLoadHandler);
  document.addEventListener("theme-change", window.__artalkThemeHandler);

  scheduleArtalkMount();
</script>
