---
import IconMail from "@/assets/icons/IconMail.svg";
import { SOCIALS } from "@/constants";
import { SITE } from "@/config";
import { getLocaleFromPath, ui, type Locale } from "@/i18n";

type Props = {
  compact?: boolean;
  locale?: Locale;
};

const { compact = false, locale = getLocaleFromPath(Astro.url.pathname) } =
  Astro.props;
const copy = ui[locale];

const emailLink = SOCIALS.find(social => social.href.startsWith("mailto:"));
const emailAddress = emailLink?.href.replace("mailto:", "");
const emailLabel = `${copy.nav.email} ${SITE.title}`;
---

<section
  class:list={[
    compact
      ? "rounded-2xl border border-border/70 bg-background/80 p-4"
      : "space-y-3",
  ]}
>
  <div class:list={[compact ? "flex items-start gap-4" : "space-y-3"]}>
    <div class="h-20 w-20 overflow-hidden rounded-full border border-border/60">
      <img
        src="/avatar.avif"
        alt={`${SITE.author} avatar`}
        class="h-full w-full object-cover"
        loading="eager"
      />
    </div>

    <div class="min-w-0 flex-1">
      <p class="text-[0.74rem] tracking-[0.28em] text-foreground/42 uppercase">
        {copy.sidebar.notebook}
      </p>
      <h2
        class:list={[
          "leading-tight font-medium",
          compact ? "mt-2 text-[1.55rem]" : "text-[1.45rem]",
        ]}
      >
        {SITE.author}
      </h2>
      <p
        class:list={[
          "text-[0.97rem] leading-7 text-foreground/62",
          compact ? "mt-3 max-w-none" : "max-w-[18rem]",
        ]}
      >
        {copy.site.desc}
      </p>
      {
        emailLink && emailAddress && (
          <a
            href={emailLink.href}
            class="mt-3 inline-flex items-center gap-2 text-[0.98rem] leading-7 text-foreground/76 underline decoration-border decoration-1 underline-offset-4 transition hover:text-accent"
            title={emailLabel}
          >
            <IconMail class="size-4.5 flex-none" />
            <span>{emailAddress}</span>
          </a>
        )
      }
    </div>
  </div>
</section>
