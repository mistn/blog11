---
import { SITE } from "@/config";
import { getLocaleFromPath, localizePath, normalizePath, ui } from "@/i18n";

const { pathname } = Astro.url;
const locale = getLocaleFromPath(pathname);
const copy = ui[locale];
const currentPath = normalizePath(pathname);
const getHref = (path: string) => localizePath(path, locale);
const isActive = (path: string) => currentPath === normalizePath(getHref(path));

const tabClass =
  "home-tab relative inline-flex items-center px-0.5 py-1 text-base font-medium text-foreground/55 transition hover:text-foreground after:absolute after:-bottom-0.5 after:left-1/2 after:h-[2px] after:w-0 after:-translate-x-1/2 after:rounded-full after:bg-accent after:transition-all after:duration-200 after:content-['']";
const activeTabClass =
  "font-semibold text-foreground after:w-4";
---

<nav
  data-home-tabs
  class="flex min-w-0 flex-wrap items-center gap-x-6 gap-y-2 text-sm translate-y-[3px]"
>
  <a
    href={getHref("/")}
    data-path={getHref("/")}
    class:list={[tabClass, { [activeTabClass]: isActive("/") }]}
  >
    {copy.nav.home}
  </a>
  {
    SITE.showArchives && (
      <a
        href={getHref("/archives")}
        data-path={getHref("/archives")}
        class:list={[tabClass, { [activeTabClass]: isActive("/archives") }]}
      >
        {copy.nav.archives}
      </a>
    )
  }
  <a
    href={getHref("/anime")}
    data-path={getHref("/anime")}
    class:list={[tabClass, { [activeTabClass]: isActive("/anime") }]}
  >
    {copy.nav.anime}
  </a>
  <a
    href={getHref("/friends")}
    data-path={getHref("/friends")}
    class:list={[tabClass, { [activeTabClass]: isActive("/friends") }]}
  >
    {copy.nav.friends}
  </a>
  <a
    href={getHref("/about")}
    data-path={getHref("/about")}
    class:list={[tabClass, { [activeTabClass]: isActive("/about") }]}
  >
    {copy.nav.about}
  </a>
</nav>

<script is:inline>
  const ACTIVE_HOME_TAB_CLASSES = ["font-semibold", "text-foreground"];

  function normalizeHomeTabPath(path) {
    if (!path) return "/";
    return path.endsWith("/") && path !== "/" ? path.slice(0, -1) : path;
  }

  function syncHomeTabs() {
    const currentPath = normalizeHomeTabPath(window.location.pathname);

    document.querySelectorAll("[data-home-tabs] [data-path]").forEach(tab => {
      const targetPath = normalizeHomeTabPath(tab.getAttribute("data-path"));
      const isActive = targetPath === currentPath;

      ACTIVE_HOME_TAB_CLASSES.forEach(className => {
        tab.classList.toggle(className, isActive);
      });
    });
  }

  document.addEventListener("astro:page-load", syncHomeTabs);
  syncHomeTabs();
</script>
