---
import type { CollectionEntry } from "astro:content";
import Socials from "@/components/Socials.astro";
import { getPath } from "@/utils/getPath";
import { SITE } from "@/config";

type Props = {
  posts: CollectionEntry<"blog">[];
};

const { posts } = Astro.props;
const latestPosts = posts.slice(0, 5);
const recentCount = Math.min(posts.length, SITE.postPerIndex);
---

<aside transition:persist class="space-y-5">
  <section class="rounded-[1.55rem] border border-[#e7dece] bg-[#fcfaf5] px-6 py-5 dark:border-[#42516b] dark:bg-[#2a3347]">
    <div class="text-[11px] uppercase tracking-[0.28em] text-foreground/45">Contact</div>
    <div class="mt-3">
      <Socials />
    </div>
  </section>

  <section class="rounded-[1.55rem] border border-[#e7dece] bg-[#fcfaf5] p-6 dark:border-[#42516b] dark:bg-[#2a3347]">
    <div class="text-[11px] uppercase tracking-[0.28em] text-foreground/45">Site Status</div>
    <div class="mt-5 space-y-3 text-[1rem] leading-7">
      <div class="flex items-center justify-between gap-4 border-b border-border/70 pb-3">
        <span class="text-foreground/62">Posts</span>
        <span class="font-semibold">{posts.length}</span>
      </div>
      <div class="flex items-center justify-between gap-4">
        <span class="text-foreground/62">Recent</span>
        <span class="font-semibold">{recentCount}</span>
      </div>
    </div>
  </section>

  <section class="rounded-[1.55rem] border border-black/8 bg-[#f2c8d7] p-6 dark:border-[#5d4c5a] dark:bg-[#4e3f50]">
    <div class="text-[11px] uppercase tracking-[0.28em] text-foreground/50">Latest Titles</div>
    <ul class="mt-5 space-y-4">
      {
        latestPosts.map(post => (
          <li class="border-b border-black/8 pb-4 last:border-b-0 last:pb-0 dark:border-white/10">
            <a
              href={getPath(post.id, post.filePath)}
              class="block text-[1rem] leading-7 font-medium transition hover:text-accent"
            >
              {post.data.title}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</aside>
