---
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconArchive from "@/assets/icons/IconArchive.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconLanguage from "@/assets/icons/IconLanguage.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";
import {
  getAlternateLocale,
  getLocaleFromPath,
  localizePath,
  normalizePath,
  ui,
} from "@/i18n";

const { pathname } = Astro.url;
const locale = getLocaleFromPath(pathname);
const copy = ui[locale];
const alternateLocale = getAlternateLocale(locale);
const languageHref = localizePath(pathname, alternateLocale);
const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;
const isActive = (path: string) =>
  currentPath === normalizePath(localizePath(path, locale));
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4"
>
  {copy.nav.skipToContent}
</a>

<header
  class="app-layout flex flex-col items-center justify-between sm:flex-row"
>
  <div
    id="top-nav-wrap"
    class:list={[
      "py-4 sm:py-6",
      "border-b border-border",
      "relative w-full bg-background",
      "flex items-center justify-between",
    ]}
  >
    <a
      href={localizePath("/", locale)}
      class="py-1 text-xl leading-8 font-semibold whitespace-nowrap sm:my-auto sm:text-2xl sm:leading-none"
    >
      {SITE.title}
    </a>
    <nav class="ms-2 flex items-center gap-2 sm:gap-3">
      {
        SITE.showArchives && (
          <LinkButton
            href={localizePath("/archives", locale)}
            class:list={[
              "focus-outline flex p-3 sm:p-1.5",
              {
                "[&>svg]:stroke-accent": isActive("/archives"),
              },
            ]}
            title={copy.nav.archives}
            aria-label={copy.nav.archives}
          >
            <IconArchive />
            <span class="sr-only">{copy.nav.archives}</span>
          </LinkButton>
        )
      }
      <LinkButton
        href={localizePath("/search", locale)}
        class:list={[
          "focus-outline flex p-3 sm:p-1.5",
          { "[&>svg]:stroke-accent": isActive("/search") },
        ]}
        title={copy.nav.search}
        aria-label={copy.nav.search}
      >
        <IconSearch />
        <span class="sr-only">{copy.nav.search}</span>
      </LinkButton>
      <a
        href={languageHref}
        data-locale-target={alternateLocale}
        data-astro-reload
        class="group inline-flex items-center gap-1 focus-outline p-3 hover:text-accent sm:p-1.5"
        title={copy.nav.languageLabel}
        aria-label={copy.nav.languageLabel}
      >
        <IconLanguage />
        <span class="sr-only">{copy.nav.languageLabel}</span>
      </a>
      {
        SITE.lightAndDarkMode && (
          <button
            id="theme-btn"
            class="focus-outline relative size-12 p-4 text-foreground/68 transition hover:text-accent sm:size-9"
            title={copy.nav.theme}
            aria-label="auto"
            aria-live="polite"
          >
            <span
              data-theme-icon-anchor
              class="pointer-events-none absolute top-[50%] left-[50%] size-5 -translate-[50%]"
              aria-hidden="true"
            >
              <IconMoon class="absolute inset-0 h-full w-full scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
              <IconSunHigh class="absolute inset-0 h-full w-full scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
            </span>
          </button>
        )
      }
    </nav>
  </div>
</header>
