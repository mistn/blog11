---
import type { CollectionEntry } from "astro:content";
import { getPath } from "@/utils/getPath";
import { getLocaleFromPath, localizePath, type Locale } from "@/i18n";
import Datetime from "./Datetime.astro";
import { getReadingStats } from "@/utils/readingTime";

type Props = {
  variant?: "h2" | "h3" | "home";
  locale?: Locale;
} & CollectionEntry<"blog">;

const {
  variant: Heading = "h2",
  locale = getLocaleFromPath(Astro.url.pathname),
  id,
  data,
  filePath,
  body,
} = Astro.props;

const { title, description, ...props } = data;
const isHome = Heading === "home";
const HeadingTag = isHome ? "h2" : Heading;
const stats = getReadingStats(body || "");
---

<li
  class:list={[
    isHome
      ? "group border-b border-border/80 py-7 first:pt-0 last:border-b-0 last:pb-0"
      : "my-5",
  ]}
>
  <a
    href={localizePath(getPath(id, filePath), locale)}
    data-post-link
    class:list={[
      "card-link-press",
      isHome
        ? "inline-block text-[1.45rem] leading-tight font-medium tracking-tight text-foreground transition group-hover:text-accent active:opacity-60"
        : "inline-block text-[1.45rem] leading-tight font-medium text-foreground transition hover:text-accent active:opacity-60",
      isHome
        ? "decoration-dashed underline-offset-4"
        : "decoration-dashed underline-offset-4",
      "focus-visible:no-underline focus-visible:underline-offset-0",
    ]}
  >
    <HeadingTag>{title}</HeadingTag>
  </a>
  <div
    class:list={[
      "flex flex-wrap items-center gap-2.5 text-xs",
      isHome
        ? "mt-1.5 text-foreground/55 [&_svg]:scale-75 [&_svg]:opacity-70"
        : "mt-1.5 text-foreground/52 [&_svg]:scale-75 [&_svg]:opacity-70",
    ]}
  >
    <Datetime {...props} locale={locale} class="" />
    <span class="inline-flex items-center gap-1">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
      {stats.readingTime}m
    </span>
  </div>
  <p
    class:list={[
      isHome
        ? "mt-1.5 max-w-3xl text-[1rem] leading-8 text-foreground/86"
        : "mt-1.5 max-w-3xl text-[1rem] leading-8 text-foreground/80",
    ]}
  >
    {description}
  </p>
</li>
